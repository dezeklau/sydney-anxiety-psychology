---
import Base from '../layouts/Base.astro';
import { practitioners } from '../data/practitioners';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Sydney Anxiety Psychology",
  "description": "Directory helping people in Sydney find AHPRA-registered telehealth psychologists who specialise in anxiety.",
  "url": "https://sydneyanxietypsychology.com.au/",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://sydneyanxietypsychology.com.au/connect/",
    "query-input": "required name=search_term_string"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do I need a referral to see a psychologist online?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No referral is needed to book directly. However, a Mental Health Treatment Plan (MHTP) from your GP is required to claim Medicare rebates. Without one, the full fee applies. From November 2025, rebates generally require the referral to come from your usual GP or a practice where you are enrolled via MyMedicare."
      }
    },
    {
      "@type": "Question",
      "name": "Is telehealth as effective as seeing a psychologist in person?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Research consistently supports telehealth psychology as effective for anxiety disorders. CBT delivered via video call produces outcomes comparable to in-person delivery for most presentations."
      }
    },
    {
      "@type": "Question",
      "name": "How many sessions will I need?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This varies by presentation and goals. Evidence-based anxiety treatments typically involve 8 to 12 sessions. Medicare covers up to 10 per calendar year under Better Access, with a GP review after the first 6. Your psychologist will discuss expectations in the first appointment."
      }
    },
    {
      "@type": "Question",
      "name": "What kind of anxiety do listed psychologists treat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The directory focuses on psychologists working with anxiety broadly: generalised anxiety disorder (GAD), panic disorder, social anxiety, health anxiety, agoraphobia, and OCD."
      }
    },
    {
      "@type": "Question",
      "name": "I keep hitting waitlists. What can I do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Telehealth expands your options beyond your suburb to the full pool of NSW practitioners. Book your GP Mental Health Treatment Plan in parallel with your psychologist search rather than after."
      }
    },
    {
      "@type": "Question",
      "name": "Can I find an anxiety psychologist near me in Sydney?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. With telehealth, every AHPRA-registered psychologist in NSW is effectively near you. A video appointment from home is the same rebate as an in-person visit under Medicare Better Access. You are not limited to psychologists in your suburb or postcode. The directory lists practitioners across Sydney who offer telehealth for anxiety."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need to travel to see an anxiety psychologist in Sydney?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Telehealth psychology sessions via video call attract the same Medicare rebate as in-person appointments under the Better Access scheme (MBS items 91170 and 91167, from 1 July 2025). You do not need to travel to a clinic. Sessions take place via a secure video platform from wherever you are comfortable."
      }
    }
  ]
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "How to Access a Telehealth Psychologist for Anxiety in Sydney",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "See your GP for a Mental Health Treatment Plan"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Find an AHPRA-registered psychologist who specialises in anxiety and offers telehealth"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Attend telehealth sessions via video call"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Claim your Medicare rebate after each session"
    }
  ]
};
---
<Base
  title="Telehealth Psychologist for Anxiety Sydney | Medicare Rebates | Finder"
  description="Find an AHPRA-registered telehealth psychologist specialising in anxiety in Sydney. Clear fees, Medicare rebate information, and no waitlist surprises."
  schema={[schema, itemListSchema, faqSchema]}
>
  <section class="hero">
    <div class="container">
      <p class="hero__label">Telehealth Psychologist Directory: Sydney</p>
      <h1 class="hero__headline">Find a Telehealth Psychologist for Anxiety in Sydney</h1>
      <p class="hero__subheadline">
        Finding the right psychologist takes effort most people do not have spare. This directory makes it simpler — clear fees, Medicare information, and a direct path to an AHPRA-registered telehealth psychologist who works with anxiety.
      </p>
      <div class="hero__cta-group">
        <a href="/directory/" class="btn btn--primary plausible-event-name=Hero+CTA+Click">
          Browse the Directory
        </a>
        <a href="/connect/" class="btn btn--secondary plausible-event-name=Hero+Connect+Click">
          Get matched — reply within 1 business day
        </a>
      </div>
      <div class="trust-strip">
        <div class="trust-strip__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
          AHPRA-registered psychologists
        </div>
        <div class="trust-strip__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>
          Medicare rebates available
        </div>
        <div class="trust-strip__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg>
          Sydney-wide telehealth
        </div>
      </div>
    </div>
  </section>

  <div class="main-content">
    <div class="container">

      <div class="info-box">
        <p><strong>Telehealth psychology attracts the same Medicare rebate as in-person.</strong> With a Mental Health Treatment Plan from your GP, you can claim <strong>$98.95 per session</strong> (registered psychologist) or <strong>$145.25</strong> (endorsed clinical psychologist) on telehealth sessions. Up to 10 sessions per calendar year. <a href="/guides/cost-telehealth-psychologist-australia/">Full cost breakdown &rarr;</a></p>
      </div>

      <h2>How It Works</h2>
      <p>Getting started with a telehealth psychologist for anxiety is a four-step process. You can <a href="/guides/how-telehealth-psychology-works/">read the full walkthrough</a>, or here is the overview:</p>

      <!-- HTML/CSS pathway stepper: accessible, responsive, no SVG text overflow -->
      <nav aria-label="Medicare Better Access pathway steps">
        <ol class="pathway-stepper" role="list" style="align-items: stretch;">
          <li class="pathway-stepper__step">
            <div class="pathway-stepper__card">
              <span class="pathway-stepper__num" aria-hidden="true">1</span>
              <span class="pathway-stepper__label">See your GP</span>
              <span class="pathway-stepper__note">Get a Mental Health Treatment Plan for Medicare rebates</span>
            </div>
            <span class="pathway-stepper__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
          </li>
          <li class="pathway-stepper__step">
            <div class="pathway-stepper__card">
              <span class="pathway-stepper__num" aria-hidden="true">2</span>
              <span class="pathway-stepper__label">Find a psychologist</span>
              <span class="pathway-stepper__note">AHPRA-registered, anxiety-specialist, telehealth-ready</span>
            </div>
            <span class="pathway-stepper__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
          </li>
          <li class="pathway-stepper__step">
            <div class="pathway-stepper__card">
              <span class="pathway-stepper__num" aria-hidden="true">3</span>
              <span class="pathway-stepper__label">Telehealth session</span>
              <span class="pathway-stepper__note">Video call from home, 50&ndash;60 min, no travel required</span>
            </div>
            <span class="pathway-stepper__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
          </li>
          <li class="pathway-stepper__step">
            <div class="pathway-stepper__card">
              <span class="pathway-stepper__num" aria-hidden="true">4</span>
              <span class="pathway-stepper__label">Claim your rebate</span>
              <span class="pathway-stepper__note">Via Medicare app, MyGov, or Medicare service centre</span>
            </div>
          </li>
        </ol>
      </nav>
      <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-top: 0.5rem;">Medicare Better Access scheme. Rebates: MBS items 91170 and 91167, effective 1 July 2025. Up to 10 sessions per calendar year. <a href="/guides/cost-telehealth-psychologist-australia/">Full cost guide &rarr;</a></p>

      <div class="cta-block">
        <h3>Ready to find a telehealth psychologist for anxiety?</h3>
        <p>Tell us a little about what you are looking for and we will connect you with a suitable psychologist in Sydney. You will hear back within 1 business day.</p>
        <a href="/connect/" class="btn--cta plausible-event-name=Mid+CTA+Click">
          Connect me with a psychologist
        </a>
        <p class="cta-block__note">Free to use. We will ask your name, email, and suburb. Nothing more.</p>
      </div>

      <h2>Why Telehealth for Anxiety?</h2>
      <p>Telehealth is not a lesser alternative to in-person therapy. Research consistently supports it as an effective format that works well for anxiety, and attending from home reduces the practical threshold for many people.</p>

      <div class="pillar-grid" style="grid-template-columns: repeat(2, 1fr);">
        <div class="pillar-card">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg></span>
          <h3>Same Medicare rebates</h3>
          <p>Telehealth psychology attracts the same rebate as in-person under Better Access. No difference in coverage.</p>
        </div>
        <div class="pillar-card">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/></svg></span>
          <h3>Effective for anxiety</h3>
          <p>Telehealth CBT and other evidence-based therapies produce outcomes comparable to in-person for most anxiety presentations. <a href="/guides/does-online-therapy-work-for-anxiety/">See the evidence &rarr;</a></p>
        </div>
        <div class="pillar-card">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
          <h3>Access more practitioners</h3>
          <p>Not limited to your suburb. Telehealth opens the full pool of practitioners across NSW, which typically means shorter waits. <a href="/guides/psychologist-waitlist-sydney/">About waitlists &rarr;</a></p>
        </div>
        <div class="pillar-card">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
          <h3>Attend from home</h3>
          <p>No travel, no waiting room, no commute. Useful when anxiety itself makes leaving the house harder — a session from your own environment can feel less daunting.</p>
        </div>
      </div>

      <h2>What Does It Cost?</h2>
      <p>The total cost depends on the psychologist's fee and whether you have a Mental Health Treatment Plan from your GP.</p>

      <div class="fee-table-wrap">
      <table class="fee-table">
        <thead>
          <tr>
            <th>Situation</th>
            <th>Medicare rebate</th>
            <th>Typical out-of-pocket</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Registered psychologist, MHTP in place (item 91170)</td>
            <td>$98.95/session</td>
            <td>$50&ndash;$150 depending on the practitioner's fee</td>
          </tr>
          <tr>
            <td>Endorsed clinical psychologist, MHTP in place (item 91167)</td>
            <td>$145.25/session</td>
            <td>$85&ndash;$165 depending on the practitioner's fee</td>
          </tr>
          <tr>
            <td>No MHTP (self-referred)</td>
            <td>No rebate</td>
            <td>Full fee: typically $150&ndash;$310/session</td>
          </tr>
          <tr>
            <td>Bulk-billing psychologist</td>
            <td>Rebate covers full fee</td>
            <td>$0 (limited availability)</td>
          </tr>
        </tbody>
      </table>
      </div>
      <p style="font-size: 0.85rem; color: var(--color-text-secondary);">Rebates: Medicare Benefits Schedule, effective 1 July 2025. MBS items 91170 and 91167. <a href="/guides/cost-telehealth-psychologist-australia/">Full cost guide including the GP MHTP process &rarr;</a></p>

      <h2>Browse the Practitioner Directory</h2>
      <p>The directory lists AHPRA-registered psychologists in Sydney who work with anxiety. Browse by suburb or specialty area, compare fees and experience, or use the finder to be matched with a practitioner directly.</p>
      <div style="background: var(--color-accent-soft); border: 1.5px solid var(--color-accent-light); border-radius: var(--radius-lg); padding: 1.5rem 1.75rem; margin: 1.25rem 0; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem;">
        <div>
          <strong style="display: block; font-size: 1.05rem; margin-bottom: 0.3rem; color: var(--color-accent-hover);">{practitioners.length} psychologists listed</strong>
          <p style="margin: 0; font-size: 0.92rem; color: var(--color-text-secondary);">Filter by specialty, sort by price or experience, and view full profiles.</p>
        </div>
        <a href="/directory/" class="btn btn--primary plausible-event-name=Homepage+Directory+CTA+Click" style="font-size: 0.97rem; white-space: nowrap;">
          Browse directory &rarr;
        </a>
      </div>

      <h2>Guides and Resources</h2>
      <p>The guides people read most before their first appointment:</p>
      <div class="pillar-grid" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); margin-bottom: 1.5rem;">
        <a href="/guides/cost-telehealth-psychologist-australia/" class="pillar-card" style="text-decoration: none;">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg></span>
          <h3 style="margin-top:0;">What does it cost?</h3>
          <p style="font-size: 0.87rem;">Fees, Medicare rebates, and the out-of-pocket gap — before you book.</p>
        </a>
        <a href="/guides/mental-health-care-plan-sydney/" class="pillar-card" style="text-decoration: none;">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span>
          <h3 style="margin-top:0;">Getting a Mental Health Care Plan</h3>
          <p style="font-size: 0.87rem;">What to say to your GP, and how to get the Medicare referral you need.</p>
        </a>
        <a href="/guides/how-telehealth-psychology-works/" class="pillar-card" style="text-decoration: none;">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg></span>
          <h3 style="margin-top:0;">How telehealth sessions work</h3>
          <p style="font-size: 0.87rem;">Technology, privacy, what to expect — if you have never done it before.</p>
        </a>
        <a href="/guides/bulk-billing-psychologist-sydney/" class="pillar-card" style="text-decoration: none;">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
          <h3 style="margin-top:0;">Bulk billing — what actually exists</h3>
          <p style="font-size: 0.87rem;">Why it is rare, and what low-cost options are genuinely available in Sydney.</p>
        </a>
        <a href="/guides/psychologist-waitlist-sydney/" class="pillar-card" style="text-decoration: none;">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
          <h3 style="margin-top:0;">Hitting waitlists?</h3>
          <p style="font-size: 0.87rem;">Practical steps to be seen sooner, without compromising on the right fit.</p>
        </a>
        <a href="/guides/does-online-therapy-work-for-anxiety/" class="pillar-card" style="text-decoration: none;">
          <span class="pillar-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/></svg></span>
          <h3 style="margin-top:0;">Does online therapy actually work?</h3>
          <p style="font-size: 0.87rem;">What the research says about telehealth CBT for anxiety.</p>
        </a>
      </div>
      <p style="font-size: 0.9rem; color: var(--color-text-secondary);">
        <a href="/guides/">Browse all guides &rarr;</a>&nbsp;&nbsp;|&nbsp;&nbsp;<a href="/guides/telehealth-anxiety-psychology-sydney/">Complete guide: telehealth anxiety psychology in Sydney &rarr;</a>
      </p>

      <h2>Free Tools</h2>
      <p>Two quick tools to answer your cost and eligibility questions before you book. No email required.</p>
      <ul>
        <li><a href="/tools/medicare-rebate-calculator/">Medicare rebate and gap calculator</a> — enter your psychologist's fee and see your exact out-of-pocket cost after Medicare</li>
        <li><a href="/tools/mental-health-care-plan-checker/">Mental Health Care Plan eligibility checker</a> — 5 questions, instant result, personalised next steps</li>
      </ul>

      <div class="faq">
        <h2>Common Questions</h2>
        <details class="faq__item">
          <summary class="faq__q">Do I need a referral to see a psychologist online?</summary>
          <p class="faq__a">No referral is needed to book directly. However, a Mental Health Treatment Plan (MHTP) from your GP is required to claim Medicare rebates. Without one, the full fee applies. From November 2025, rebates generally require the referral to come from your usual GP or a practice where you are enrolled via MyMedicare. <a href="/guides/cost-telehealth-psychologist-australia/#mental-health-treatment-plan">How the MHTP works &rarr;</a></p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">Is telehealth as effective as seeing a psychologist in person?</summary>
          <p class="faq__a">Research consistently supports telehealth psychology as effective for anxiety disorders. CBT delivered via video call produces outcomes comparable to in-person delivery for most presentations. <a href="/guides/does-online-therapy-work-for-anxiety/">More on the evidence &rarr;</a></p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">How many sessions will I need?</summary>
          <p class="faq__a">This varies by presentation and goals. Evidence-based anxiety treatments typically involve 8 to 12 sessions. Medicare covers up to 10 per calendar year under Better Access, with a GP review after the first 6. Your psychologist will discuss expectations in the first appointment.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">What kind of anxiety do listed psychologists treat?</summary>
          <p class="faq__a">The directory focuses on psychologists working with anxiety broadly: generalised anxiety disorder (GAD), panic disorder, social anxiety, health anxiety, agoraphobia, and OCD. When you make contact, specify the presentation and we will match accordingly.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">I keep hitting waitlists. What can I do?</summary>
          <p class="faq__a">Telehealth expands your options beyond your suburb to the full pool of NSW practitioners. Book your GP Mental Health Treatment Plan in parallel with your psychologist search rather than after. <a href="/guides/psychologist-waitlist-sydney/">Guide: waitlists and how to be seen sooner &rarr;</a></p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">Can I find an anxiety psychologist near me in Sydney?</summary>
          <p class="faq__a">Yes. With telehealth, every AHPRA-registered psychologist in NSW is effectively near you. A video appointment from home attracts the same Medicare rebate as an in-person visit under Better Access. You are not limited to psychologists in your suburb or postcode. <a href="/directory/">Browse the directory &rarr;</a></p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">Do I need to travel to see an anxiety psychologist in Sydney?</summary>
          <p class="faq__a">No. Telehealth sessions via video call attract the same Medicare rebate as in-person appointments under Better Access (MBS items 91170 and 91167, from 1 July 2025). No travel required. Sessions take place from wherever you feel comfortable. <a href="/guides/how-telehealth-psychology-works/">How telehealth sessions work &rarr;</a></p>
        </details>
      </div>

      <div class="cta-block">
        <h3>Take the first step</h3>
        <p>If you are ready to connect with a telehealth psychologist who specialises in anxiety, tell us a little about what you are looking for. You will hear back within 1 business day.</p>
        <a href="/connect/" class="btn--cta plausible-event-name=Bottom+CTA+Click">
          Find a psychologist for anxiety
        </a>
        <p class="cta-block__note">No obligation. We connect you. We do not provide clinical services.</p>
      </div>

    </div>
  </div>
</Base>
