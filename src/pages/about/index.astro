const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Sydney Anxiety Psychology",
  "description": "About this directory: what it is, how practitioner listings are sourced and verified, editorial standards, and how to request removal or report inaccuracies.",
