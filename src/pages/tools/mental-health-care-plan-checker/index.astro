---
import Base from '../../../layouts/Base.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sydneyanxietypsychology.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Free Tools", "item": "https://sydneyanxietypsychology.com.au/tools/" },
    { "@type": "ListItem", "position": 3, "name": "Mental Health Care Plan Checker", "item": "https://sydneyanxietypsychology.com.au/tools/mental-health-care-plan-checker/" },
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Mental Health Care Plan Eligibility Checker",
  "description": "Answer 5 quick questions to find out whether you are likely eligible for a Mental Health Treatment Plan and what steps to take to access Medicare-rebated psychology.",
  "url": "https://sydneyanxietypsychology.com.au/tools/mental-health-care-plan-checker/",
  "applicationCategory": "HealthApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "AUD"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Sydney Anxiety Psychology",
    "url": "https://sydneyanxietypsychology.com.au"
  }
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to get a Mental Health Treatment Plan in Australia",
  "description": "Steps to access Medicare-rebated psychology in Australia via a GP Mental Health Treatment Plan.",
  "totalTime": "PT45M",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Check your eligibility",
      "text": "Most Australians experiencing mental health difficulties (including anxiety, depression, or stress) are eligible. Your GP will assess your needs.",
      "url": "https://sydneyanxietypsychology.com.au/tools/mental-health-care-plan-checker/#step-1"
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Book a longer GP appointment",
      "text": "Request a 30-minute appointment for a 'mental health plan' or 'MHTP'. Standard 10-minute appointments are not sufficient.",
      "url": "https://sydneyanxietypsychology.com.au/tools/mental-health-care-plan-checker/#step-2"
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Tell your GP what you are experiencing",
      "text": "Describe your symptoms honestly. You do not need clinical language. 'I have been struggling with anxiety and want psychology support' is enough.",
      "url": "https://sydneyanxietypsychology.com.au/tools/mental-health-care-plan-checker/#step-3"
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Receive your Mental Health Treatment Plan",
      "text": "Your GP prepares the plan and refers you to a psychologist. You are then eligible for Medicare rebates on up to 10 psychology sessions per calendar year.",
      "url": "https://sydneyanxietypsychology.com.au/tools/mental-health-care-plan-checker/#step-4"
    },
    {
      "@type": "HowToStep",
      "position": 5,
      "name": "Book with a psychologist",
      "text": "Find an AHPRA-registered psychologist who accepts MHTP referrals and book. Mention that you have (or will have) an MHTP when booking.",
      "url": "https://sydneyanxietypsychology.com.au/tools/mental-health-care-plan-checker/#step-5"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who is eligible for a Mental Health Treatment Plan in Australia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Any Australian with a Medicare card who has a mental health condition (including anxiety, depression, stress, OCD, PTSD, and others) that their GP agrees warrants psychological support is eligible for a Mental Health Treatment Plan. There is no strict diagnostic threshold — your GP uses clinical judgement. Being in psychological distress is sufficient. Concession card holders and children also qualify."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need a diagnosis to get a Mental Health Treatment Plan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. You do not need a formal diagnosis to get a Mental Health Treatment Plan. Your GP will conduct a brief mental health assessment and use their clinical judgement. Describing what you are experiencing — anxiety, worry, low mood, stress affecting daily life — is enough. You do not need to use clinical terms or have seen a mental health professional before."
      }
    },
    {
      "@type": "Question",
      "name": "Can I get a Mental Health Treatment Plan if I have private health insurance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Having private health insurance does not affect your eligibility for a Mental Health Treatment Plan or Medicare rebates. You cannot claim both Medicare and private health insurance for the same session, but the MHTP and Medicare rebate are available to all eligible Medicare cardholders regardless of private insurance status."
      }
    },
    {
      "@type": "Question",
      "name": "Can children get a Mental Health Treatment Plan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Children can access Mental Health Treatment Plans through their GP. A parent or guardian typically attends the appointment. The same Medicare rebates apply for psychology sessions with children."
      }
    },
    {
      "@type": "Question",
      "name": "Can I get a Mental Health Treatment Plan from a telehealth GP?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. A Mental Health Treatment Plan can be prepared by a GP via telehealth. From November 2025, Medicare rebates generally require the referral to come from your usual or treating GP (linked to MyMedicare), rather than a one-off telehealth GP service. If you have an existing GP, a telehealth appointment with them for your MHTP is straightforward."
      }
    }
  ]
};
---
<Base
  title="Mental Health Care Plan Eligibility Checker | Do I Qualify? | Sydney"
  description="Answer 5 quick questions to find out if you are likely eligible for a Mental Health Treatment Plan and Medicare-rebated psychology in Australia. Free, private, instant result."
  schema={[breadcrumbSchema, webAppSchema, howToSchema, faqSchema]}
>
  <div class="main-content">
    <div class="container" style="max-width: 720px;">

      <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1.5rem;">
        <a href="/">Home</a> &rsaquo; <a href="/tools/">Tools</a> &rsaquo; Mental Health Care Plan checker
      </p>

      <h1>Mental Health Care Plan Eligibility Checker</h1>
      <p style="font-size: 1.05rem; color: var(--color-text-secondary); margin-bottom: 0.5rem;">Answer 5 questions to find out whether you are likely eligible for a Mental Health Treatment Plan (MHTP) — and what to do next.</p>
      <p style="font-size: 0.82rem; color: var(--color-text-secondary); margin-bottom: 2rem;">Nothing you enter is stored or transmitted. Results are informational only — your GP makes the final determination.</p>

      <div class="info-box" style="margin-bottom: 2rem;">
        <p><strong>What is a Mental Health Treatment Plan?</strong> A document your GP prepares that gives you access to Medicare rebates on up to 10 psychology sessions per calendar year under the Better Access scheme. With one, your Medicare rebate is $98.95/session (registered psychologist) or $145.25/session (clinical psychologist), effective 1 July 2025.</p>
      </div>

      <!-- CHECKER APP -->
      <div id="checker-app" style="background: #f8fafc; border: 1.5px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 2rem;">

        <!-- Question 1 -->
        <div class="checker-q" id="q1" style="margin-bottom: 1.75rem;">
          <p style="font-weight: 600; margin-bottom: 0.75rem;" id="step-1">1. Do you have a Medicare card?</p>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q1" value="yes" style="accent-color: var(--color-accent);" /> Yes — I have a Medicare card
            </label>
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q1" value="no" style="accent-color: var(--color-accent);" /> No / not sure
            </label>
          </div>
        </div>

        <!-- Question 2 -->
        <div class="checker-q" id="q2" style="margin-bottom: 1.75rem;">
          <p style="font-weight: 600; margin-bottom: 0.75rem;" id="step-2">2. Are you experiencing mental health difficulties that are affecting your daily life?</p>
          <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 0.6rem;">This includes anxiety, worry, low mood, stress, OCD, PTSD, panic attacks, social anxiety, or other psychological distress. No diagnosis required.</p>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q2" value="yes" style="accent-color: var(--color-accent);" /> Yes
            </label>
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q2" value="no" style="accent-color: var(--color-accent);" /> I'm not sure / my difficulties feel mild
            </label>
          </div>
        </div>

        <!-- Question 3 -->
        <div class="checker-q" id="q3" style="margin-bottom: 1.75rem;">
          <p style="font-weight: 600; margin-bottom: 0.75rem;" id="step-3">3. Do you have (or can you access) a GP?</p>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q3" value="regular" style="accent-color: var(--color-accent);" /> Yes, I have a regular GP
            </label>
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q3" value="any" style="accent-color: var(--color-accent);" /> I can see a GP, but not a regular one
            </label>
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q3" value="no" style="accent-color: var(--color-accent);" /> I don't currently have access to a GP
            </label>
          </div>
        </div>

        <!-- Question 4 -->
        <div class="checker-q" id="q4" style="margin-bottom: 1.75rem;">
          <p style="font-weight: 600; margin-bottom: 0.75rem;" id="step-4">4. Have you already used 10 Medicare-rebated psychology sessions this calendar year?</p>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q4" value="no" style="accent-color: var(--color-accent);" /> No, I haven't used 10 sessions yet this year
            </label>
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q4" value="yes" style="accent-color: var(--color-accent);" /> Yes, I have already used 10 this year
            </label>
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q4" value="unsure" style="accent-color: var(--color-accent);" /> I'm not sure
            </label>
          </div>
        </div>

        <!-- Question 5 -->
        <div class="checker-q" id="q5" style="margin-bottom: 1.75rem;">
          <p style="font-weight: 600; margin-bottom: 0.75rem;" id="step-5">5. Are you looking to access telehealth (video) or in-person psychology?</p>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q5" value="telehealth" style="accent-color: var(--color-accent);" /> Telehealth (video call from home)
            </label>
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q5" value="inperson" style="accent-color: var(--color-accent);" /> In-person (at a clinic)
            </label>
            <label style="display: flex; align-items: center; gap: 0.6rem; cursor: pointer; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); background: #fff; font-size: 0.95rem;">
              <input type="radio" name="q5" value="either" style="accent-color: var(--color-accent);" /> Either / not sure yet
            </label>
          </div>
        </div>

        <button
          id="checker-btn"
          style="background: var(--color-accent); color: #fff; border: none; border-radius: var(--radius); padding: 0.8rem 2rem; font-size: 1rem; font-weight: 600; cursor: pointer; width: 100%;"
          aria-label="Check my eligibility"
        >
          Check my eligibility
        </button>

      </div>

      <!-- RESULT -->
      <div id="checker-result" style="display:none; border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 2rem;" aria-live="polite" aria-atomic="true">
      </div>

      <script is:inline>
        (function() {
          document.getElementById('checker-btn').addEventListener('click', function() {
            var q1 = document.querySelector('input[name="q1"]:checked');
            var q2 = document.querySelector('input[name="q2"]:checked');
            var q3 = document.querySelector('input[name="q3"]:checked');
            var q4 = document.querySelector('input[name="q4"]:checked');
            var q5 = document.querySelector('input[name="q5"]:checked');

            if (!q1 || !q2 || !q3 || !q4 || !q5) {
              alert('Please answer all 5 questions to see your result.');
              return;
            }

            var v1 = q1.value, v2 = q2.value, v3 = q3.value, v4 = q4.value, v5 = q5.value;
            var resultEl = document.getElementById('checker-result');
            var html = '';

            // No Medicare card
            if (v1 === 'no') {
              html = '<div style="background:#fff3cd;border:2px solid #f59e0b;border-radius:var(--radius-lg);padding:1.5rem;">';
              html += '<h2 style="margin-top:0;color:#92400e;">Medicare card required</h2>';
              html += '<p>Medicare rebates for psychology require a Medicare card. If you are an Australian citizen or permanent resident, you are generally entitled to Medicare — enrolment is via <a href="https://www.servicesaustralia.gov.au/how-to-enrol-in-medicare" target="_blank" rel="noopener">Services Australia</a>. Temporary residents and international students may have different entitlements depending on your visa and home country\'s reciprocal agreement with Australia.</p>';
              html += '<p>Without a Medicare card, you can still see a psychologist and pay the full fee. Some community mental health services and university counselling centres offer reduced-fee or free sessions without Medicare.</p>';
              html += '</div>';
            }
            // No GP access
            else if (v3 === 'no') {
              html = '<div style="background:#fff3cd;border:2px solid #f59e0b;border-radius:var(--radius-lg);padding:1.5rem;">';
              html += '<h2 style="margin-top:0;color:#92400e;">You need a GP to get the plan</h2>';
              html += '<p>A Mental Health Treatment Plan must be prepared by a GP or other eligible medical practitioner. To access Medicare-rebated psychology, finding a GP first is the essential step.</p>';
              html += '<p><strong>Options for finding a GP in Sydney:</strong></p><ul><li>Search HotDoc or HealthEngine for bulk-billing GPs near you.</li><li>Community health centres often offer GP services regardless of financial situation.</li><li>Telehealth GP services (e.g. Eucalyptus, Instant Scripts) can prepare MHTPs if you meet their criteria — check their eligibility requirements.</li></ul>';
              html += '</div>';
            }
            // Cap hit
            else if (v4 === 'yes') {
              html = '<div style="background:#fff3cd;border:2px solid #f59e0b;border-radius:var(--radius-lg);padding:1.5rem;">';
              html += '<h2 style="margin-top:0;color:#92400e;">10-session cap reached for this year</h2>';
              html += '<p>Medicare rebates under the Better Access scheme are limited to 10 sessions per calendar year. If you have already used 10 this year, further sessions are still available — but without the Medicare rebate. The session count resets on 1 January.</p>';
              html += '<p><strong>Options:</strong></p><ul><li>Continue sessions without the Medicare rebate until 1 January, then access a new year\'s 10 sessions.</li><li>Some private health insurance extras cover psychology sessions — check your policy if you have extras cover.</li><li>Discuss with your psychologist whether your current frequency is the most effective use of your sessions.</li></ul>';
              html += '</div>';
            }
            // Good to go
            else {
              var uncertainty = v2 === 'no' || v3 === 'any';
              var telehealth = v5 === 'telehealth' || v5 === 'either';

              html = '<div style="background:#f0fdf4;border:2px solid #16a34a;border-radius:var(--radius-lg);padding:1.5rem;">';
              html += '<h2 style="margin-top:0;color:#166534;">You are likely eligible for a Mental Health Treatment Plan</h2>';

              if (uncertainty) {
                html += '<p style="background:#fefce8;border-left:4px solid #ca8a04;padding:0.75rem;border-radius:var(--radius);"><strong>Note:</strong> ';
                if (v2 === 'no') html += 'Even if your difficulties feel mild, a GP can assess whether an MHTP is appropriate. The bar is not a crisis — persistent worry, low-level anxiety, or stress affecting your day-to-day life is enough to discuss with a GP. ';
                if (v3 === 'any') html += 'From November 2025, Medicare rebates generally require the referral to come from your usual or treating GP (your "MyMedicare" GP). If you do not have a regular GP, finding and enrolling with one before seeking the MHTP is advisable. ';
                html += '</p>';
              }

              html += '<h3 style="margin-top:1.5rem;">Your next steps</h3>';
              html += '<ol style="line-height:2;">';
              html += '<li><strong>Book a longer GP appointment</strong> — request 30 minutes and mention you want to discuss a mental health plan.</li>';
              html += '<li><strong>Tell your GP what you\'re experiencing</strong> — describe your symptoms honestly. "I\'ve been struggling with anxiety and want psychology support" is enough.</li>';
              html += '<li><strong>Receive your MHTP</strong> — your GP prepares the plan and refers you for up to 6 sessions (then up to 4 more after review). Total: 10 sessions per year.</li>';
              html += '<li><strong>Find a psychologist</strong> — ';
              if (telehealth) {
                html += 'our <a href="/directory/">telehealth psychologist directory</a> lists AHPRA-registered psychologists in Sydney who accept MHTP referrals and offer video sessions.';
              } else {
                html += 'find an AHPRA-registered psychologist who accepts MHTP referrals. You are not locked to a specific psychologist — you can choose.';
              }
              html += '</li>';
              html += '<li><strong>Book and attend your first session</strong> — mention your MHTP when booking. Your Medicare rebate is $98.95/session (registered psychologist) or $145.25/session (clinical psychologist).</li>';
              html += '</ol>';

              html += '<div style="margin-top:1.5rem;padding:1rem;background:#dcfce7;border-radius:var(--radius);">';
              html += '<strong>Your Medicare rebate:</strong> $98.95/session (registered psychologist) or $145.25/session (clinical psychologist). Both apply to telehealth and in-person sessions equally. Rates from the Medicare Benefits Schedule, effective 1 July 2025.';
              html += '</div>';

              html += '</div>';
            }

            resultEl.innerHTML = html;
            resultEl.style.display = 'block';
            resultEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
        })();
      </script>

      <!-- HOW-TO STEPS -->
      <h2>How to Get a Mental Health Treatment Plan: Step by Step</h2>
      <p>A Mental Health Treatment Plan (MHTP) is prepared by your GP and takes one appointment. Here is what each step involves.</p>

      <ol class="steps" id="step-1">
        <li>
          <div>
            <strong>Check your eligibility</strong>
            <p>Most Australians with a Medicare card who are experiencing mental health difficulties are eligible. No formal diagnosis is needed. Your GP assesses your needs at the appointment.</p>
          </div>
        </li>
        <li id="step-2">
          <div>
            <strong>Book a longer GP appointment</strong>
            <p>A standard 10-minute slot is not enough. When booking, ask for a 30-minute or "longer" appointment and mention you want to discuss mental health. If your GP uses online booking, look for "mental health" or "long consultation" options.</p>
          </div>
        </li>
        <li id="step-3">
          <div>
            <strong>Tell your GP what you are experiencing</strong>
            <p>Describe your symptoms in plain language. You do not need clinical terminology. Saying "I've been struggling with anxiety and it's affecting my sleep and work" is sufficient. Your GP will ask follow-up questions. Be honest — this is not an assessment you can fail.</p>
          </div>
        </li>
        <li id="step-4">
          <div>
            <strong>Receive your Mental Health Treatment Plan</strong>
            <p>Your GP prepares the MHTP document, which includes a brief mental health assessment and a referral for psychology. They initially refer you for up to 6 sessions. After those 6 sessions, a GP review allows you to access up to 4 more (10 total per year).</p>
          </div>
        </li>
        <li id="step-5">
          <div>
            <strong>Book with a psychologist</strong>
            <p>You can choose your own psychologist — you are not restricted to the GP's suggestion. Tell the psychologist you have an MHTP when booking. For telehealth, see our <a href="/directory/">directory of telehealth psychologists in Sydney</a> who accept MHTP referrals.</p>
          </div>
        </li>
      </ol>

      <div class="faq">
        <h2>Common Questions</h2>
        <details class="faq__item">
          <summary class="faq__q">Who is eligible for a Mental Health Treatment Plan?</summary>
          <p class="faq__a">Any Australian with a Medicare card whose GP agrees they would benefit from psychological support. No specific diagnosis is required. Anxiety, depression, stress, OCD, PTSD, and other mental health difficulties are all valid grounds. Children are also eligible.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">Do I need a diagnosis to get an MHTP?</summary>
          <p class="faq__a">No. You do not need a formal diagnosis. Your GP conducts a brief mental health assessment and uses their clinical judgement. Describing what you are experiencing is enough — you do not need to have seen a specialist before.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">Can I use telehealth for the GP appointment to get an MHTP?</summary>
          <p class="faq__a">Yes. A GP can prepare a Mental Health Treatment Plan via telehealth. From November 2025, rebates generally require the referral from your usual GP. If you have a regular GP, a telehealth appointment with them is straightforward.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">Does having an MHTP lock me in to a specific psychologist?</summary>
          <p class="faq__a">No. Your MHTP is a referral to psychology services generally, not to a specific practitioner. You can use it with any AHPRA-registered psychologist who participates in the Better Access scheme. You can also change psychologists mid-plan.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">What if I have already had therapy before?</summary>
          <p class="faq__a">Having had previous therapy does not affect your eligibility. If you have ongoing mental health needs, your GP can prepare a new MHTP. The 10-session cap resets each calendar year regardless of your history.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">Does the Mental Health Treatment Plan cover telehealth psychology?</summary>
          <p class="faq__a">Yes. Medicare rebates under an MHTP apply equally to telehealth (video) and in-person psychology sessions. The rebate is identical: $98.95/session (registered psychologist) or $145.25/session (clinical psychologist), effective 1 July 2025.</p>
        </details>
      </div>

      <div style="margin-top: 2.5rem; margin-bottom: 2rem;">
        <h3>Related resources</h3>
        <ul>
          <li><a href="/guides/mental-health-care-plan-sydney/">Full guide: Mental Health Care Plan Sydney — how to get one and what it covers</a></li>
          <li><a href="/guides/cost-telehealth-psychologist-australia/">What does a telehealth psychologist cost in Australia?</a></li>
          <li><a href="/tools/medicare-rebate-calculator/">Medicare rebate &amp; gap calculator</a></li>
