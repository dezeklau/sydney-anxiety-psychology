---
import Base from '../../../layouts/Base.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sydneyanxietypsychology.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Free Tools", "item": "https://sydneyanxietypsychology.com.au/tools/" },
    { "@type": "ListItem", "position": 3, "name": "Medicare Rebate Calculator", "item": "https://sydneyanxietypsychology.com.au/tools/medicare-rebate-calculator/" },
  ]
};

const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Medicare Psychology Rebate & Gap Calculator",
  "description": "Calculate your Medicare rebate and out-of-pocket gap for psychology sessions under the Better Access scheme. Works for both registered and endorsed clinical psychologists.",
  "url": "https://sydneyanxietypsychology.com.au/tools/medicare-rebate-calculator/",
  "applicationCategory": "HealthApplication",
  "operatingSystem": "All",
  "isAccessibleForFree": true,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "AUD"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Sydney Anxiety Psychology",
    "url": "https://sydneyanxietypsychology.com.au"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the Medicare rebate for a psychologist session in Australia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Medicare rebate for a psychology session under the Better Access scheme (with a Mental Health Treatment Plan) is $98.95 per session for a registered psychologist (MBS item 91170) or $145.25 per session for an endorsed clinical psychologist (MBS item 91167). These rates are effective from 1 July 2025. Telehealth sessions attract the same rebate as in-person sessions."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate my out-of-pocket gap for psychology?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Your out-of-pocket gap is the difference between your psychologist's full session fee and the Medicare rebate. For example, if your psychologist charges $220 and the rebate is $98.95 (registered psychologist), your gap is $121.05 per session. If your psychologist bulk bills, the gap is $0 — they accept the rebate as full payment."
      }
    },
    {
      "@type": "Question",
      "name": "Does Medicare cover telehealth psychology the same as in-person?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Telehealth psychology sessions under the Better Access scheme attract the same Medicare rebate as in-person sessions. The relevant MBS items are 91170 (registered psychologist, telehealth) and 91167 (endorsed clinical psychologist, telehealth), effective 1 July 2025."
      }
    },
    {
      "@type": "Question",
      "name": "How many sessions does Medicare cover per year for psychology?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Under the Better Access scheme, Medicare covers up to 10 individual psychology sessions per calendar year with a Mental Health Treatment Plan. The first 6 sessions are available on the initial referral; after a GP review, up to 4 more sessions become available. Sessions reset each calendar year on 1 January."
      }
    }
  ]
};
---
<Base
  title="Medicare Psychology Rebate Calculator — 2025 Rates | Sydney Anxiety Psychology"
  description="Calculate your exact Medicare rebate and out-of-pocket gap for psychology sessions. Uses 2025 Better Access rebate rates ($98.95 registered / $145.25 clinical psychologist). Free, private, no email required."
  schema={[breadcrumbSchema, webAppSchema, faqSchema]}
>
  <div class="main-content">
    <div class="container" style="max-width: 720px;">

      <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1.5rem;">
        <a href="/">Home</a> &rsaquo; <a href="/tools/">Tools</a> &rsaquo; Medicare rebate calculator
      </p>

      <h1>Medicare Psychology Rebate &amp; Gap Calculator</h1>
      <p style="font-size: 1.05rem; color: var(--color-text-secondary); margin-bottom: 0.5rem;">Enter your psychologist's session fee to see your exact out-of-pocket cost after Medicare. Uses July 2025 Better Access rebate rates.</p>
      <p style="font-size: 0.82rem; color: var(--color-text-secondary); margin-bottom: 2rem;">Nothing you enter is stored or transmitted. All calculations happen in your browser.</p>

      <!-- CALCULATOR -->
      <div id="calc-app" style="background: #f8fafc; border: 1.5px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 2rem;">

        <div style="margin-bottom: 1.5rem;">
          <label for="psych-type" style="display: block; font-weight: 600; margin-bottom: 0.5rem;">
            1. Type of psychologist
          </label>
          <select id="psych-type" style="width: 100%; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); font-size: 1rem; background: #fff;" aria-describedby="psych-type-help">
            <option value="registered">Registered psychologist (MBS item 91170) — rebate: $98.95</option>
            <option value="clinical">Endorsed clinical psychologist (MBS item 91167) — rebate: $145.25</option>
          </select>
          <p id="psych-type-help" style="font-size: 0.82rem; color: var(--color-text-secondary); margin-top: 0.4rem;">Not sure? <a href="/guides/clinical-psychologist-vs-registered-psychologist/">Clinical vs registered psychologist explained &rarr;</a></p>
        </div>

        <div style="margin-bottom: 1.5rem;">
          <label for="session-fee" style="display: block; font-weight: 600; margin-bottom: 0.5rem;">
            2. Your psychologist's session fee ($)
          </label>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span style="font-size: 1.1rem; color: var(--color-text-secondary);">$</span>
            <input
              type="number"
              id="session-fee"
              min="0"
              max="1000"
              step="1"
              placeholder="e.g. 220"
              style="width: 100%; max-width: 180px; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); font-size: 1.1rem; background: #fff;"
              aria-describedby="fee-help"
            />
          </div>
          <p id="fee-help" style="font-size: 0.82rem; color: var(--color-text-secondary); margin-top: 0.4rem;">Typical Sydney range: $150&ndash;$230 (registered) or $230&ndash;$310 (clinical). Leave blank to see bulk billing scenario.</p>
        </div>

        <div style="margin-bottom: 1.5rem;">
          <label for="num-sessions" style="display: block; font-weight: 600; margin-bottom: 0.5rem;">
            3. Number of sessions (optional, for annual savings)
          </label>
          <input
            type="number"
            id="num-sessions"
            min="1"
            max="10"
            step="1"
            value="10"
            style="width: 100px; padding: 0.65rem 0.85rem; border: 1px solid var(--color-border); border-radius: var(--radius); font-size: 1rem; background: #fff;"
            aria-describedby="sessions-help"
          />
          <p id="sessions-help" style="font-size: 0.82rem; color: var(--color-text-secondary); margin-top: 0.4rem;">Medicare covers up to 10 sessions per calendar year with a Mental Health Treatment Plan.</p>
        </div>

        <div style="margin-bottom: 1rem;">
          <label style="display: flex; align-items: center; gap: 0.6rem; font-size: 0.95rem; cursor: pointer;">
            <input type="checkbox" id="has-mhtp" checked style="width: 18px; height: 18px; accent-color: var(--color-accent);" />
            <span>I have (or will get) a Mental Health Treatment Plan from my GP</span>
          </label>
          <p style="font-size: 0.82rem; color: var(--color-text-secondary); margin-top: 0.4rem; margin-left: 1.6rem;">Required to claim Medicare rebates. <a href="/guides/mental-health-care-plan-sydney/">How to get one &rarr;</a></p>
        </div>

        <button
          id="calc-btn"
          style="background: var(--color-accent); color: #fff; border: none; border-radius: var(--radius); padding: 0.8rem 2rem; font-size: 1rem; font-weight: 600; cursor: pointer; width: 100%; margin-top: 0.5rem;"
          aria-label="Calculate my rebate"
        >
          Calculate
        </button>
      </div>

      <!-- RESULTS (hidden until calculated) -->
      <div id="calc-results" style="display: none; background: #fff; border: 2px solid var(--color-accent); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 2rem;" aria-live="polite" aria-atomic="true">
        <h2 style="margin-top: 0; font-size: 1.2rem; color: var(--color-accent-hover);">Your results</h2>
        <div id="results-content"></div>
        <p style="font-size: 0.78rem; color: var(--color-text-secondary); margin-top: 1.5rem; border-top: 1px solid var(--color-border); padding-top: 0.75rem;">Rebate figures: Medicare Benefits Schedule, effective 1 July 2025. MBS items 91170 (registered) and 91167 (clinical). Verify at <a href="https://www.mbsonline.gov.au" target="_blank" rel="noopener">mbsonline.gov.au</a>. This calculator is for informational guidance only — not financial advice.</p>
      </div>

      <script is:inline>
        (function() {
          var REBATES = { registered: 98.95, clinical: 145.25 };

          function fmt(n) {
            return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
          }

          function calculate() {
            var type = document.getElementById('psych-type').value;
            var feeRaw = document.getElementById('session-fee').value;
            var sessions = parseInt(document.getElementById('num-sessions').value, 10) || 10;
            var hasMhtp = document.getElementById('has-mhtp').checked;
            var fee = parseFloat(feeRaw);
            var rebate = REBATES[type];
            var rebateLabel = type === 'registered' ? 'Registered psychologist (item 91170)' : 'Endorsed clinical psychologist (item 91167)';

            var resultsEl = document.getElementById('calc-results');
            var contentEl = document.getElementById('results-content');

            if (!hasMhtp) {
              contentEl.innerHTML = '<div style="background:#fff3cd;border-left:4px solid #f59e0b;padding:1rem 1.25rem;border-radius:var(--radius);margin-bottom:1rem;"><strong>No Medicare rebate without an MHTP</strong><p style="margin:0.5rem 0 0;">Without a Mental Health Treatment Plan from your GP, no Medicare rebate applies and you pay the full session fee. <a href="/guides/mental-health-care-plan-sydney/">How to get an MHTP &rarr;</a></p></div>';
              if (!isNaN(fee) && fee > 0) {
                var totalFull = fee * sessions;
                contentEl.innerHTML += '<table style="width:100%;border-collapse:collapse;font-size:0.95rem;"><tbody><tr><td style="padding:0.6rem 0;border-bottom:1px solid var(--color-border);">Session fee</td><td style="text-align:right;padding:0.6rem 0;border-bottom:1px solid var(--color-border);">' + fmt(fee) + '</td></tr><tr><td style="padding:0.6rem 0;border-bottom:1px solid var(--color-border);">Medicare rebate</td><td style="text-align:right;padding:0.6rem 0;border-bottom:1px solid var(--color-border);">$0.00</td></tr><tr><td style="padding:0.6rem 0;border-bottom:1px solid var(--color-border);font-weight:600;">Out-of-pocket per session</td><td style="text-align:right;padding:0.6rem 0;border-bottom:1px solid var(--color-border);font-weight:600;">' + fmt(fee) + '</td></tr><tr><td style="padding:0.6rem 0;color:var(--color-text-secondary);">Total cost (' + sessions + ' sessions, no MHTP)</td><td style="text-align:right;padding:0.6rem 0;color:var(--color-text-secondary);">' + fmt(totalFull) + '</td></tr></tbody></table>';
              }
              resultsEl.style.display = 'block';
              return;
            }

            var isBulkBill = isNaN(fee) || fee === 0 || feeRaw.trim() === '';

            if (isBulkBill) {
              contentEl.innerHTML = '<div style="background:#f0fdf4;border-left:4px solid #16a34a;padding:1rem 1.25rem;border-radius:var(--radius);margin-bottom:1rem;"><strong>Bulk billing scenario: $0 out-of-pocket</strong><p style="margin:0.5rem 0 0;">If your psychologist bulk bills, they accept the Medicare rebate (' + fmt(rebate) + ') as full payment. You pay nothing. Bulk billing psychology is limited in availability in Sydney. <a href="/guides/bulk-billing-psychologist-sydney/">More about bulk billing &rarr;</a></p></div>';
              contentEl.innerHTML += '<table style="width:100%;border-collapse:collapse;font-size:0.95rem;"><tbody><tr><td style="padding:0.6rem 0;border-bottom:1px solid var(--color-border);">Psychologist type</td><td style="text-align:right;padding:0.6rem 0;border-bottom:1px solid var(--color-border);">' + rebateLabel + '</td></tr><tr><td style="padding:0.6rem 0;border-bottom:1px solid var(--color-border);">Medicare rebate</td><td style="text-align:right;padding:0.6rem 0;border-bottom:1px solid var(--color-border);">' + fmt(rebate) + '</td></tr><tr><td style="padding:0.6rem 0;font-weight:600;">Out-of-pocket (bulk billed)</td><td style="text-align:right;padding:0.6rem 0;font-weight:600;">$0.00</td></tr></tbody></table>';
              resultsEl.style.display = 'block';
              return;
            }

            var gap = Math.max(0, fee - rebate);
            var totalFee = fee * sessions;
            var totalRebate = Math.min(rebate, fee) * sessions;
            var totalGap = gap * sessions;
            var saving = totalRebate;

            var html = '<table style="width:100%;border-collapse:collapse;font-size:0.95rem;margin-bottom:1rem;">';
            html += '<tbody>';
            html += '<tr><td style="padding:0.6rem 0;border-bottom:1px solid var(--color-border);">Psychologist type</td><td style="text-align:right;padding:0.6rem 0;border-bottom:1px solid var(--color-border);">' + rebateLabel + '</td></tr>';
            html += '<tr><td style="padding:0.6rem 0;border-bottom:1px solid var(--color-border);">Full session fee</td><td style="text-align:right;padding:0.6rem 0;border-bottom:1px solid var(--color-border);">' + fmt(fee) + '</td></tr>';
            html += '<tr><td style="padding:0.6rem 0;border-bottom:1px solid var(--color-border);color:#16a34a;">Medicare rebate</td><td style="text-align:right;padding:0.6rem 0;border-bottom:1px solid var(--color-border);color:#16a34a;">&minus;' + fmt(Math.min(rebate, fee)) + '</td></tr>';
            html += '<tr style="background:#f8fafc;"><td style="padding:0.75rem 0.5rem;font-weight:700;font-size:1.1rem;">Your out-of-pocket gap</td><td style="text-align:right;padding:0.75rem 0.5rem;font-weight:700;font-size:1.1rem;">' + fmt(gap) + ' per session</td></tr>';
            html += '</tbody></table>';

            if (sessions > 1) {
              html += '<div style="background:#f0f4ff;border-radius:var(--radius);padding:1rem 1.25rem;margin-bottom:1rem;">';
              html += '<p style="font-weight:600;margin:0 0 0.5rem;">Over ' + sessions + ' sessions:</p>';
              html += '<table style="width:100%;border-collapse:collapse;font-size:0.9rem;">';
              html += '<tr><td style="padding:0.4rem 0;">Total cost (no Medicare)</td><td style="text-align:right;">' + fmt(totalFee) + '</td></tr>';
              html += '<tr><td style="padding:0.4rem 0;color:#16a34a;">Total Medicare saves you</td><td style="text-align:right;color:#16a34a;">&minus;' + fmt(saving) + '</td></tr>';
              html += '<tr><td style="padding:0.4rem 0;font-weight:700;">Your total out-of-pocket</td><td style="text-align:right;font-weight:700;">' + fmt(totalGap) + '</td></tr>';
              html += '</table>';
              html += '</div>';
            }

            if (fee < rebate) {
              html += '<div style="background:#fefce8;border-left:4px solid #ca8a04;padding:0.75rem 1rem;border-radius:var(--radius);font-size:0.88rem;"><strong>Note:</strong> If a psychologist charges less than the rebate, they must bulk bill — they cannot accept a payment lower than the rebate under Medicare rules. This situation (fee below rebate) is uncommon.</div>';
            }

            contentEl.innerHTML = html;
            resultsEl.style.display = 'block';
          }

          document.getElementById('calc-btn').addEventListener('click', calculate);

          // Allow Enter key in inputs
          ['session-fee','num-sessions'].forEach(function(id) {
            document.getElementById(id).addEventListener('keydown', function(e) {
              if (e.key === 'Enter') calculate();
            });
          });
        })();
      </script>

      <!-- FAQ SECTION -->
      <h2>How Medicare Rebates for Psychology Work</h2>

      <div class="info-box">
        <p><strong>The one-sentence answer:</strong> With a Mental Health Treatment Plan from your GP, Medicare pays $98.95 of each registered psychologist session (or $145.25 for a clinical psychologist) and you pay the difference between that rebate and your psychologist's fee — regardless of whether the session is in-person or via telehealth. Medicare Benefits Schedule, effective 1 July 2025.</p>
      </div>

      <h3>Key facts</h3>
      <ul>
        <li><strong>Rebate requires a Mental Health Treatment Plan (MHTP):</strong> Your GP prepares this at a longer appointment. Without it, no Medicare rebate applies and you pay the full fee.</li>
        <li><strong>Same rebate for telehealth and in-person:</strong> MBS items 91170 (registered psychologist, telehealth) and 91167 (clinical psychologist, telehealth) carry the same rebate as their in-person equivalents.</li>
        <li><strong>10 sessions per calendar year:</strong> The 10-session cap runs January to December. Sessions reset on 1 January each year.</li>
        <li><strong>Bulk billing means $0 out-of-pocket:</strong> Some psychologists accept the Medicare rebate as their full fee. This is uncommon in Sydney for telehealth; most have a gap.</li>
        <li><strong>Claiming the rebate:</strong> Your psychologist may claim on your behalf (if they bulk bill) or you claim via the Medicare app, myGov, or at a Medicare service centre after paying.</li>
      </ul>

      <div class="faq">
        <h2>Common Questions</h2>
        <details class="faq__item">
          <summary class="faq__q">What is the Medicare rebate for a psychologist session?</summary>
          <p class="faq__a">With a Mental Health Treatment Plan, the rebate is <strong>$98.95 per session</strong> for a registered psychologist (MBS item 91170) or <strong>$145.25 per session</strong> for an endorsed clinical psychologist (MBS item 91167). Both apply equally to telehealth and in-person sessions. Rates are from the Medicare Benefits Schedule effective 1 July 2025.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">How do I calculate my gap?</summary>
          <p class="faq__a">Subtract the Medicare rebate from your psychologist's full session fee. For example: a $220 session minus the $98.95 rebate = $121.05 out-of-pocket. Use the calculator above to get exact figures.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">Does Medicare cover telehealth psychology?</summary>
          <p class="faq__a">Yes. Telehealth psychology sessions attract the same rebate as in-person sessions under the Better Access scheme. There is no difference in coverage or rebate amount.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">How many sessions does Medicare cover per year?</summary>
          <p class="faq__a">Up to 10 individual psychology sessions per calendar year with a Mental Health Treatment Plan. Your GP refers you for up to 6 first, then reviews and can refer for up to 4 more.</p>
        </details>
        <details class="faq__item">
          <summary class="faq__q">Do I need a new plan each year?</summary>
          <p class="faq__a">Yes. Your GP needs to review and renew your Mental Health Treatment Plan at the start of each new year for you to access the next year's 10 sessions.</p>
        </details>
      </div>

      <div style="margin-top: 2.5rem; margin-bottom: 2rem;">
        <h3>Related resources</h3>
        <ul>
          <li><a href="/guides/cost-telehealth-psychologist-australia/">Full cost guide: what a telehealth psychologist costs in Australia</a></li>
          <li><a href="/guides/mental-health-care-plan-sydney/">How to get a Mental Health Care Plan in Sydney</a></li>
          <li><a href="/guides/bulk-billing-psychologist-sydney/">Bulk billing psychology in Sydney: what is actually available</a></li>
          <li><a href="/tools/mental-health-care-plan-checker/">Mental Health Care Plan eligibility checker</a></li>
          <li><a href="/guides/clinical-psychologist-vs-registered-psychologist/">Clinical vs registered psychologist: which rebate applies?</a></li>
        </ul>
      </div>

      <div class="cta-block">
        <h3>Know your cost — now find a psychologist</h3>
        <p>Our directory lists AHPRA-registered telehealth psychologists in Sydney who specialise in anxiety. Browse fees, compare experience, and connect directly.</p>
        <a href="/directory/" class="btn--cta plausible-event-name=Calc+Tool+CTA+Click">
          Browse the directory
        </a>
        <p class="cta-block__note">Or <a href="/connect/">request a personal match &rarr;</a></p>
      </div>

    </div>
  </div>
</Base>
