---
import Base from '../../layouts/Base.astro';
import { practitioners } from '../../data/practitioners';

export async function getStaticPaths() {
  return practitioners.map((p) => ({
    params: { slug: p.slug },
    props: { practitioner: p },
  }));
}

const { practitioner: p } = Astro.props;

const registrationLabel =
  p.registrationType === "clinical_psychologist"
    ? "Clinical psychologist (AHPRA endorsed)"
    : "Registered psychologist";

const pageTitle = `${p.name}, ${registrationLabel} in ${p.suburb} | Sydney Anxiety Psychology`;
const pageDescription = `${p.name} is a ${registrationLabel.toLowerCase()} based in ${p.suburb}, listed on the Sydney Anxiety Psychology telehealth directory.`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sydneyanxietypsychology.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Directory", "item": "https://sydneyanxietypsychology.com.au/directory/" },
    { "@type": "ListItem", "position": 3, "name": p.name, "item": `https://sydneyanxietypsychology.com.au/directory/${p.slug}/` },
  ]
};

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "name": pageTitle,
  "url": `https://sydneyanxietypsychology.com.au/directory/${p.slug}/`,
  "mainEntity": {
    "@type": "Person",
    "name": p.name,
    "jobTitle": registrationLabel,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": p.suburb,
      "addressRegion": "NSW",
      "addressCountry": "AU"
    }
  }
};
---
<Base
  title={pageTitle}
  description={pageDescription}
  schema={[breadcrumbSchema, profilePageSchema]}
>
  <div class="main-content">
    <div class="container">

      <!-- Breadcrumb -->
      <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1.5rem;">
        <a href="/">Home</a> &rsaquo; <a href="/directory/">Directory</a> &rsaquo; {p.name}
      </p>

      {p.unclaimed && (
        <!-- Unclaimed banner -->
        <div style="background: #fffbeb; border: 1.5px solid #f59e0b; border-radius: var(--radius); padding: 1.25rem 1.5rem; margin-bottom: 2rem; display: flex; flex-wrap: wrap; gap: 0.75rem 2rem; align-items: center;">
          <div style="flex: 1 1 280px;">
            <strong style="color: #92400e; display: block; margin-bottom: 0.25rem; font-size: 1rem;">Unclaimed profile</strong>
            <p style="margin: 0; font-size: 0.93rem; color: #78350f;">
              This profile was pre-built from the AHPRA public register. Is this you?
              Claiming takes two minutes and unlocks inbound patient enquiries at no cost.
            </p>
          </div>
          <div style="display: flex; flex-direction: column; gap: 0.5rem; flex-shrink: 0;">
            <a href="/for-psychologists/" class="btn btn--primary" style="font-size: 0.9rem; padding: 0.65rem 1.35rem; background: #d97706; color: #fff;">
              Claim this profile free
            </a>
            <a href="/listing-removal/" style="font-size: 0.8rem; color: #92400e; text-align: center;">
              Request removal
            </a>
          </div>
        </div>
      )}

      <!-- Profile header -->
      <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 2rem; box-shadow: var(--shadow-sm);">
        <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: flex-start;">

          <!-- Avatar placeholder -->
          <div style="width: 72px; height: 72px; border-radius: 50%; background: var(--color-accent-soft); border: 2px solid var(--color-accent-light); display: flex; align-items: center; justify-content: center; flex-shrink: 0;" aria-hidden="true">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>

          <div style="flex: 1 1 200px;">
            <h1 style="font-size: clamp(1.5rem, 4vw, 2rem); margin-bottom: 0.25rem;">{p.name}</h1>
            <p style="font-size: 1rem; color: var(--color-accent); font-weight: 600; margin-bottom: 0.35rem;">{registrationLabel}</p>
            <p style="font-size: 0.95rem; color: var(--color-text-secondary); margin-bottom: 0; display: flex; align-items: center; gap: 0.4rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              {p.suburb}, NSW
            </p>
          </div>

          {p.unclaimed && (
            <div style="flex-shrink: 0;">
              <span style="display: inline-block; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #92400e; background: #fef3c7; border: 1px solid #f59e0b; padding: 0.3rem 0.7rem; border-radius: 100px;">
                Unclaimed
              </span>
            </div>
          )}
        </div>
      </div>

      <!-- Public register details -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin-bottom: 2rem;">

        <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.35rem; box-shadow: var(--shadow-sm);">
          <p style="font-size: 0.74rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-accent-hover); margin-bottom: 0.5rem;">Registration type</p>
          <p style="font-size: 0.96rem; color: var(--color-text); font-weight: 600; margin-bottom: 0;">{registrationLabel}</p>
          <p style="font-size: 0.8rem; color: var(--color-text-secondary); margin-top: 0.35rem; margin-bottom: 0;">
            Verify at <a href="https://www.ahpra.gov.au/Registration/Registers-of-Practitioners.aspx" target="_blank" rel="noopener">ahpra.gov.au</a>
          </p>
        </div>

        <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.35rem; box-shadow: var(--shadow-sm);">
          <p style="font-size: 0.74rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-accent-hover); margin-bottom: 0.5rem;">Principal practice suburb</p>
          <p style="font-size: 0.96rem; color: var(--color-text); font-weight: 600; margin-bottom: 0;">{p.suburb}, NSW</p>
          <p style="font-size: 0.8rem; color: var(--color-text-secondary); margin-top: 0.35rem; margin-bottom: 0;">As recorded on AHPRA public register</p>
        </div>

        {p.specialties.length > 0 && (
          <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.35rem; box-shadow: var(--shadow-sm);">
            <p style="font-size: 0.74rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-accent-hover); margin-bottom: 0.5rem;">Publicly listed specialty areas</p>
            <div style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0;">
              {p.specialties.map(s => (
                <span style="display: inline-block; font-size: 0.82rem; background: var(--color-accent-soft); color: var(--color-accent-hover); border: 1px solid var(--color-accent-light); padding: 0.2rem 0.65rem; border-radius: 100px;">{s}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Source notice -->
      <div class="info-box" style="margin-bottom: 2rem;">
        <p style="font-size: 0.88rem;">
          <strong>About this listing:</strong> This profile was generated from the
          <a href="https://www.ahpra.gov.au/Registration/Registers-of-Practitioners.aspx" target="_blank" rel="noopener">AHPRA public register</a>.
          It shows only publicly available information: name, registration type, and principal practice suburb.
          No contact details are published. This profile is marked unclaimed and has not been reviewed or
          verified by the practitioner. If you are this practitioner, you can claim it free below.
          If you would prefer it removed, use the <a href="/listing-removal/">removal request page</a>.
        </p>
      </div>

      {p.unclaimed && (
        <!-- Second claim CTA -->
        <div class="cta-block">
          <h3>Are you {p.name}?</h3>
          <p>
            Claim this profile in two minutes and start receiving inbound patient enquiries at no cost.
            Your profile is pre-filled with your name, registration type, and suburb. You add your
            specialties, telehealth preference, and booking link.
          </p>
          <a href="/for-psychologists/" class="btn--cta plausible-event-name=Profile+Claim+CTA+Click">
            Claim this profile free
          </a>
          <p class="cta-block__note">No referral fee. No subscription. Free to claim and free to stay.</p>
        </div>
      )}

      <!-- For patients: connect CTA -->
      <div style="background: var(--color-surface-alt); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2rem; margin-top: 2rem;">
        <h2 style="margin-top: 0; font-size: 1.3rem;">Looking for a telehealth psychologist for anxiety?</h2>
        <p>This is an unclaimed profile from the AHPRA public register. Contact details are not available here yet. Use our finder to connect with a practitioner who can see you soon.</p>
        <a href="/connect/" class="btn btn--primary plausible-event-name=Profile+Connect+CTA+Click" style="font-size: 0.95rem;">
          Find a telehealth psychologist
        </a>
      </div>

    </div>
  </div>
</Base>
