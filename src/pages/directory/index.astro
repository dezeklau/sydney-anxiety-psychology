---
import Base from '../../layouts/Base.astro';
import { practitioners, allSuburbs, allSpecialties } from '../../data/practitioners';

// Group practitioners by suburb for the browsable layout
const bySuburb: Record<string, typeof practitioners> = {};
for (const p of practitioners) {
  if (!bySuburb[p.suburb]) bySuburb[p.suburb] = [];
  bySuburb[p.suburb].push(p);
}
const sortedSuburbs = Object.keys(bySuburb).sort();

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Telehealth Psychologists for Anxiety in Sydney",
  "description": "A directory of AHPRA-registered psychologists in Sydney available for telehealth appointments for anxiety.",
  "url": "https://sydneyanxietypsychology.com.au/directory/",
  "numberOfItems": practitioners.length,
  "itemListElement": practitioners.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://sydneyanxietypsychology.com.au/directory/${p.slug}/`,
    "name": p.name
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sydneyanxietypsychology.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Directory", "item": "https://sydneyanxietypsychology.com.au/directory/" },
  ]
};
---
<Base
  title="Telehealth Psychologist Directory for Anxiety in Sydney | Browse by Suburb"
  description="Browse AHPRA-registered psychologists in Sydney offering telehealth for anxiety. Organised by suburb. Profiles sourced from the AHPRA public register."
  schema={[itemListSchema, breadcrumbSchema]}
>
  <div class="main-content">
    <div class="container" style="max-width: var(--max-width-wide);">

      <!-- Breadcrumb -->
      <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1.5rem;">
        <a href="/">Home</a> &rsaquo; Directory
      </p>

      <!-- Page header -->
      <div style="margin-bottom: 2.5rem;">
        <h1 style="margin-bottom: 0.75rem;">Telehealth Psychologist Directory for Anxiety in Sydney</h1>
        <p style="font-size: 1.05rem; max-width: 680px;">
          Browse AHPRA-registered psychologists in Sydney who work with anxiety and offer telehealth.
          Profiles are sourced from the AHPRA public register and are browsable by suburb and specialty area.
        </p>
        <div class="info-box" style="max-width: 680px;">
          <p style="font-size: 0.88rem;">
            <strong>About these profiles:</strong> Profiles are pre-built from the
            <a href="https://www.ahpra.gov.au/Registration/Registers-of-Practitioners.aspx" target="_blank" rel="noopener">AHPRA public register</a>
            and marked unclaimed until the practitioner claims them. They show name, registration type, and
            suburb only. No contact details are published on unclaimed profiles. Practitioners can
            <a href="/for-psychologists/">claim their profile free</a> or
            <a href="/listing-removal/">request removal</a> at any time.
          </p>
        </div>
      </div>

      <!-- Quick stats -->
      <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem;">
        <div class="stat-card">
          <span class="stat-card__number">{practitioners.length}</span>
          <span class="stat-card__label">Practitioners listed</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number">{allSuburbs.length}</span>
          <span class="stat-card__label">Sydney suburbs</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number">{allSpecialties.length}</span>
          <span class="stat-card__label">Specialty areas</span>
        </div>
      </div>

      <!-- Browse by suburb -->
      <h2>Browse by suburb</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
        {sortedSuburbs.map(suburb => (
          <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.35rem; box-shadow: var(--shadow-sm);">
            <h3 style="margin-top: 0; font-size: 1.05rem; margin-bottom: 0.85rem;">{suburb}</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">
              {bySuburb[suburb].map(p => (
                <li style="margin-bottom: 0.7rem; padding-bottom: 0.7rem; border-bottom: 1px solid var(--color-border);">
                  <a href={`/directory/${p.slug}/`} style="font-weight: 600; text-decoration: none; color: var(--color-accent);">{p.name}</a>
                  <span style="display: block; font-size: 0.82rem; color: var(--color-text-secondary); margin-top: 0.15rem;">
                    {p.registrationType === "clinical_psychologist" ? "Clinical psychologist" : "Registered psychologist"}
                    {p.unclaimed && <span style="margin-left: 0.4rem; font-size: 0.74rem; background: #fef3c7; color: #92400e; border: 1px solid #f59e0b; padding: 0.1rem 0.45rem; border-radius: 100px;">Unclaimed</span>}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Browse by specialty -->
      <h2>Browse by specialty area</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2rem;">
        {allSpecialties.map(spec => {
          const count = practitioners.filter(p => p.specialties.includes(spec)).length;
          return (
            <span style="display: inline-flex; align-items: center; gap: 0.4rem; background: var(--color-accent-soft); border: 1px solid var(--color-accent-light); color: var(--color-accent-hover); padding: 0.35rem 0.85rem; border-radius: 100px; font-size: 0.88rem; font-weight: 500;">
              {spec}
              <span style="font-size: 0.78rem; opacity: 0.75;">({count})</span>
            </span>
          );
        })}
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; margin-bottom: 3rem;">
        {allSpecialties.map(spec => {
          const matching = practitioners.filter(p => p.specialties.includes(spec));
          return (
            <div style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.25rem; box-shadow: var(--shadow-sm);">
              <h3 style="margin-top: 0; font-size: 1rem; margin-bottom: 0.75rem; color: var(--color-accent-hover);">{spec}</h3>
              <ul style="list-style: none; padding: 0; margin: 0;">
                {matching.map(p => (
                  <li style="margin-bottom: 0.45rem;">
                    <a href={`/directory/${p.slug}/`} style="font-size: 0.93rem;">{p.name}</a>
                    <span style="font-size: 0.8rem; color: var(--color-text-secondary);"> � {p.suburb}</span>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>

      <!-- CTA for practitioners -->
      <div class="psych-cta-panel">
        <h2>Are you a psychologist in Sydney?</h2>
        <p>If you specialise in anxiety and offer telehealth, your profile may already be pre-built from the AHPRA public register. Claim it free in two minutes, add your specialties and booking link, and start receiving inbound patient enquiries.</p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.85rem; align-items: center;">
          <a href="/for-psychologists/" class="btn btn--primary" style="font-size: 0.95rem;">Claim your free listing</a>
          <a href="/listing-removal/" style="font-size: 0.9rem;">Request profile removal</a>
        </div>
      </div>

      <!-- Patient CTA -->
      <div class="cta-block">
        <h3>Need to connect with a psychologist now?</h3>
        <p>Not all profiles have been claimed yet. Tell us what you are looking for and we will connect you with a suitable telehealth psychologist for anxiety in Sydney within 1 business day.</p>
        <a href="/connect/" class="btn--cta plausible-event-name=Directory+Connect+CTA+Click">
          Find a psychologist for anxiety
        </a>
        <p class="cta-block__note">Free to use. No obligation.</p>
      </div>

    </div>
  </div>
</Base>
