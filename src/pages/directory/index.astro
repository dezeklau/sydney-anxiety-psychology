<!-- Filter + sort JavaScript — progressive enhancement only -->
<script>
(function () {
  'use strict';

  // ── Data embedded from server-rendered data-attributes ──────────────────────
  var TOTAL = document.querySelectorAll('.prac-card').length;

  // Filter term map — mirrors the Astro filterTerms object above
  var FILTER_TERMS = {
    'generalised-anxiety': ['generalised anxiety', 'generalized anxiety'],
    'social-anxiety': ['social anxiety'],
    'panic': ['panic'],
    'ocd': ['ocd'],
    'health-anxiety': ['health anxiety'],
    'trauma-ptsd': ['trauma', 'ptsd'],
    'depression': ['depression'],
    'burnout': ['burnout'],
    'womens': ["women's", 'womens', 'woman'],
    'adhd': ['adhd'],
    'lgbtqia': ['lgbtq', 'lgbtqia', 'lgbtiq'],
  };

  // Multi-select: set of active filter keys (empty = show all)
  var activeFilters = new Set();
  var activeSort = 'default';

  var grid = document.getElementById('practitioner-grid');
  var countEl = document.getElementById('filter-count');
  var noResultsEl = document.getElementById('no-results');
  var clearBtn = document.getElementById('clear-filters');
  var sortSelect = document.getElementById('sort-select');
  var chips = document.querySelectorAll('.filter-chip');

  if (!grid || !noResultsEl || !clearBtn || !sortSelect) return;

  // ── Helpers ─────────────────────────────────────────────────────────────────

  function cardMatchesFilters(card) {
    // If no filters active, show all
    if (activeFilters.size === 0) return true;
    var specs = card.getAttribute('data-specialties') || '';
    // Card matches if ANY active filter matches (OR logic)
    var matched = false;
    activeFilters.forEach(function (key) {
      if (matched) return;
      var terms = FILTER_TERMS[key] || [];
      if (terms.some(function (t) { return specs.includes(t); })) {
        matched = true;
      }
    });
    return matched;
  }

  function updateChipStyles() {
    chips.forEach(function (c) {
      var key = c.getAttribute('data-filter');
      var isAll = key === 'all';
      var isActive;
      if (isAll) {
        isActive = activeFilters.size === 0;
      } else {
        isActive = activeFilters.has(key);
      }
      c.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      c.style.background = isActive ? 'var(--color-accent)' : 'transparent';
      c.style.color = isActive ? 'white' : 'var(--color-text)';
      c.style.borderColor = isActive ? 'var(--color-accent)' : 'var(--color-border)';
      c.style.fontWeight = isActive ? '600' : '500';
    });
  }

  function applyFilterSort() {
    var cards = Array.from(grid.querySelectorAll('.prac-card'));

    // 1. Filter
    var visible = [];
    var hidden = [];
    cards.forEach(function (card) {
      if (cardMatchesFilters(card)) {
        visible.push(card);
      } else {
        hidden.push(card);
      }
    });

    // 2. Sort visible cards
    if (activeSort === 'price-asc') {
      visible.sort(function (a, b) {
        var pa = parseInt(a.getAttribute('data-price'), 10);
        var pb = parseInt(b.getAttribute('data-price'), 10);
        // -1 means no price listed — push to end
        if (pa === -1 && pb === -1) return 0;
        if (pa === -1) return 1;
        if (pb === -1) return -1;
        return pa - pb;
      });
    } else if (activeSort === 'experience-desc') {
      visible.sort(function (a, b) {
        var ea = parseInt(a.getAttribute('data-experience'), 10);
        var eb = parseInt(b.getAttribute('data-experience'), 10);
        if (ea === -1 && eb === -1) return 0;
        if (ea === -1) return 1;
        if (eb === -1) return -1;
        return eb - ea;
      });
    } else if (activeSort === 'name-asc') {
      visible.sort(function (a, b) {
        return a.getAttribute('data-name').localeCompare(b.getAttribute('data-name'));
      });
    } else if (activeSort === 'name-desc') {
      visible.sort(function (a, b) {
        return b.getAttribute('data-name').localeCompare(a.getAttribute('data-name'));
      });
    }
    // 'default' — keep original DOM order

    // 3. Re-attach in sorted order
    visible.forEach(function (card) {
      card.style.display = '';
      grid.appendChild(card);
    });
    hidden.forEach(function (card) {
      card.style.display = 'none';
    });

    // 4. Update count
    var count = visible.length;
    if (countEl) {
      if (activeFilters.size === 0 && activeSort === 'default') {
        countEl.textContent = 'Showing all ' + TOTAL + ' practitioners';
      } else {
        countEl.textContent = 'Showing ' + count + ' of ' + TOTAL + ' practitioners';
      }
    }

    // 5. No-results message
    noResultsEl.style.display = count === 0 ? 'block' : 'none';

    // 6. Show/hide clear button
    var isFiltered = activeFilters.size > 0 || activeSort !== 'default';
    clearBtn.style.display = isFiltered ? '' : 'none';
  }

  // ── Chip interaction (multi-select) ──────────────────────────────────────────

  chips.forEach(function (chip) {
    chip.addEventListener('click', function () {
      var key = chip.getAttribute('data-filter');

      if (key === 'all') {
        // "All" clears all active filters
        activeFilters.clear();
      } else {
        // Toggle this filter on/off
        if (activeFilters.has(key)) {
          activeFilters.delete(key);
        } else {
          activeFilters.add(key);
        }
      }

      updateChipStyles();
      applyFilterSort();
    });
  });

  // ── Sort interaction ──────────────────────────────────────────────────────────

  sortSelect.addEventListener('change', function () {
    activeSort = sortSelect.value;
    applyFilterSort();
    // Update clear visibility (no chip style change needed for sort)
    var isFiltered = activeFilters.size > 0 || activeSort !== 'default';
    clearBtn.style.display = isFiltered ? '' : 'none';
  });

  // ── Clear ─────────────────────────────────────────────────────────────────────

  clearBtn.addEventListener('click', function () {
    activeFilters.clear();
    activeSort = 'default';
    sortSelect.value = 'default';
    updateChipStyles();
    applyFilterSort();
  });

  // Initial chip style render
  updateChipStyles();

})();
</script>
