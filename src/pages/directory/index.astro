---
import Base from '../../layouts/Base.astro';
import { practitioners, allSpecialties } from '../../data/practitioners';

// Build a deduplicated, sorted list of all unique specialties across all practitioners
const specialtySet = new Set<string>();
for (const p of practitioners) {
  for (const s of p.specialties) {
    specialtySet.add(s);
  }
}

// Curated filter categories — map display label to one or more terms to match in specialty strings
const filterCategories = [
  { label: "All", key: "all" },
  { label: "Generalised anxiety", key: "generalised-anxiety" },
  { label: "Social anxiety", key: "social-anxiety" },
  { label: "Panic attacks", key: "panic" },
  { label: "OCD", key: "ocd" },
  { label: "Health anxiety", key: "health-anxiety" },
  { label: "Trauma & PTSD", key: "trauma-ptsd" },
  { label: "Depression", key: "depression" },
  { label: "Burnout", key: "burnout" },
  { label: "Women's health", key: "womens" },
  { label: "ADHD", key: "adhd" },
  { label: "LGBTQIA+", key: "lgbtqia" },
];

// Match terms for each filter key (used in data-specialties attribute matching)
const filterTerms: Record<string, string[]> = {
  "generalised-anxiety": ["generalised anxiety", "generalized anxiety"],
  "social-anxiety": ["social anxiety"],
  "panic": ["panic"],
  "ocd": ["ocd"],
  "health-anxiety": ["health anxiety"],
  "trauma-ptsd": ["trauma", "ptsd"],
  "depression": ["depression"],
  "burnout": ["burnout"],
  "womens": ["women's", "womens", "woman"],
  "adhd": ["adhd"],
  "lgbtqia": ["lgbtq", "lgbtqia", "lgbtiq"],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Telehealth Psychologists for Anxiety in Sydney",
  "description": "A directory of AHPRA-registered psychologists in Sydney available for telehealth appointments for anxiety.",
  "url": "https://sydneyanxietypsychology.com.au/directory/",
  "numberOfItems": practitioners.length,
  "itemListElement": practitioners.map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://sydneyanxietypsychology.com.au/directory/${p.slug}/`,
    "name": p.name
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sydneyanxietypsychology.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Directory", "item": "https://sydneyanxietypsychology.com.au/directory/" },
  ]
};
---
<Base
  title="Find a Telehealth Psychologist for Anxiety in Sydney | 34 Listed"
  description="Compare 34 AHPRA-registered psychologists in Sydney offering telehealth for anxiety. See Medicare rebate amounts, specialties, and booking options — free, no sign-up."
  schema={[itemListSchema, breadcrumbSchema]}
>
  <div class="main-content">
    <div class="container" style="max-width: var(--max-width-wide);">

      <!-- Breadcrumb -->
      <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1.5rem;">
        <a href="/">Home</a> &rsaquo; Directory
      </p>

      <!-- Page header -->
      <div style="margin-bottom: 2rem;">
        <h1 style="margin-bottom: 0.75rem;">Telehealth Psychologist Directory — Anxiety Specialists in Sydney</h1>
        <p style="font-size: 1.05rem; max-width: 680px; color: var(--color-text-secondary);">
          {practitioners.length} AHPRA-registered psychologists in Sydney who work with anxiety and offer telehealth.
          All sessions delivered online — filter below by the type of anxiety you want help with, or sort by experience.
        </p>
        <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-top: 0.5rem;">
          All listed practitioners hold current AHPRA registration. You can independently verify any practitioner at the <a href="https://www.ahpra.gov.au/Registration/Registers-of-Practitioners.aspx" target="_blank" rel="noopener">AHPRA public register</a>. Profiles marked "Unclaimed" were pre-built from publicly available sources; claimed profiles have been reviewed by the practitioner. <a href="/about/#editorial-standards">How listings work &rarr;</a>
        </p>
      </div>

      <!-- Decision aid: how to use this directory -->
      <details style="margin-bottom: 2rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1rem 1.25rem;">
        <summary style="cursor: pointer; font-weight: 600; font-size: 0.97rem; list-style: none; display: flex; align-items: center; gap: 0.5rem;">
          <span aria-hidden="true" style="font-size: 1.1rem;">?</span> Not sure who to choose or where to start? <span style="font-weight: 400; font-size: 0.9rem; color: var(--color-text-secondary); margin-left: 0.25rem;">(expand for a quick guide)</span>
        </summary>
        <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-border);">
          <p style="margin-top: 0; font-size: 0.93rem; color: var(--color-text-secondary);">Here is a straightforward way to narrow it down:</p>
          <ol style="font-size: 0.93rem; padding-left: 1.25rem; margin-bottom: 0;">
            <li style="margin-bottom: 0.6rem;"><strong>Start with your presentation.</strong> Use the filter chips below to narrow to practitioners who work with your type of anxiety — GAD, social anxiety, panic, OCD, health anxiety, PTSD, or depression alongside anxiety. Filtering typically reduces the list to 8–15 people.</li>
            <li style="margin-bottom: 0.6rem;"><strong>Check registration type.</strong> Registered psychologists and endorsed clinical psychologists are both qualified to treat anxiety. The main practical difference is the Medicare rebate amount: $98.95 (registered) vs $145.25 (endorsed clinical). <a href="/guides/clinical-psychologist-vs-registered-psychologist/">Explained fully here &rarr;</a></li>
            <li style="margin-bottom: 0.6rem;"><strong>Check fees vs your out-of-pocket.</strong> Sort by price using the sort control below. If a practitioner lists their fee, you can calculate your gap: [fee] minus [rebate] = your session cost. <a href="/guides/cost-telehealth-psychologist-australia/">Cost guide &rarr;</a></li>
            <li style="margin-bottom: 0.6rem;"><strong>Read 2–3 profiles in depth.</strong> Each profile page describes the practitioner's approach, therapeutic modalities, and experience. Look for someone whose approach description resonates — therapy is a working relationship, and fit matters.</li>
            <li><strong>Not sure after that?</strong> Use the <a href="/connect/">match request</a>. Tell us your situation and we will suggest someone. No obligation to proceed.</li>
          </ol>
        </div>
      </details>

      <!-- Quick stats -->
      <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem;">
        <div class="stat-card">
          <span class="stat-card__number">{practitioners.length}</span>
          <span class="stat-card__label">Practitioners listed</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number">{practitioners.filter(p => p.pricing).length}</span>
          <span class="stat-card__label">With public pricing</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number">{practitioners.filter(p => p.bookingUrl).length}</span>
          <span class="stat-card__label">With direct booking</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number">{practitioners.filter(p => p.yearsExperience).length}</span>
          <span class="stat-card__label">With stated experience</span>
        </div>
      </div>

      <!-- FILTER + SORT CONTROLS -->
      <div id="filter-controls" style="margin-bottom: 2rem; padding: 1.25rem 1.5rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius);">

        <!-- Specialty filter chips (multi-select) -->
        <div style="margin-bottom: 1rem;">
          <p style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-secondary); margin-bottom: 0.65rem; margin-top: 0;">
            Filter by presenting concern <span style="font-weight: 400; text-transform: none; letter-spacing: 0; font-size: 0.78rem;">(select one or more)</span>
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;" role="group" aria-label="Filter by specialty — select one or more">
            {filterCategories.map(cat => (
              <button
                class="filter-chip"
                data-filter={cat.key}
                aria-pressed={cat.key === "all" ? "true" : "false"}
                aria-label={cat.key === "all" ? "Clear filter — show all practitioners" : `Toggle filter: ${cat.label}`}
                style={cat.key === "all"
                  ? "cursor: pointer; padding: 0.35rem 0.85rem; border-radius: 100px; border: 1.5px solid var(--color-accent); background: var(--color-accent); color: white; font-size: 0.85rem; font-weight: 600; transition: all 0.15s;"
                  : "cursor: pointer; padding: 0.35rem 0.85rem; border-radius: 100px; border: 1.5px solid var(--color-border); background: transparent; color: var(--color-text); font-size: 0.85rem; font-weight: 500; transition: all 0.15s;"}
              >
                {cat.label}
              </button>
            ))}
          </div>
        </div>

        <!-- Sort + count row -->
        <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 0.75rem;">
          <p id="results-count" style="margin: 0; font-size: 0.88rem; color: var(--color-text-secondary);" aria-live="polite" aria-atomic="true">
            Showing {practitioners.length} of {practitioners.length} psychologists
          </p>
          <div style="display: flex; align-items: center; gap: 0.6rem;">
            <label for="sort-select" style="font-size: 0.85rem; color: var(--color-text-secondary); white-space: nowrap;">Sort by:</label>
            <select
              id="sort-select"
              aria-label="Sort practitioners"
              style="font-size: 0.85rem; padding: 0.3rem 0.6rem; border: 1.5px solid var(--color-border); border-radius: var(--radius); background: var(--color-background); color: var(--color-text); cursor: pointer;"
            >
              <option value="default">Default order</option>
              <option value="price-asc">Price (low to high)</option>
              <option value="experience-desc">Most experience first</option>
              <option value="name-asc">Name (A–Z)</option>
              <option value="name-desc">Name (Z–A)</option>
            </select>
            <button
              id="clear-filters"
              aria-label="Clear all filters and reset sort"
              style="font-size: 0.82rem; padding: 0.3rem 0.7rem; border: 1.5px solid var(--color-border); border-radius: var(--radius); background: transparent; color: var(--color-text-secondary); cursor: pointer; display: none;"
            >
              Clear
            </button>
          </div>
        </div>
      </div>

      <!-- Filter result count -->
      <p id="filter-count" style="font-size: 0.88rem; color: var(--color-text-secondary); margin-bottom: 1rem;" aria-live="polite" aria-atomic="true">
        Showing all {practitioners.length} practitioners
      </p>

      <!-- PRACTITIONER CARD GRID -->
      <div
        id="practitioner-grid"
        style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; margin-bottom: 3.5rem;"
        aria-label="Practitioner listings"
      >
        {practitioners.map((p) => {
          // Build a normalised specialties string for JS data-attribute matching
          const specialtiesStr = p.specialties.join("|").toLowerCase();
          const expNum = p.yearsExperience ?? -1;
          const nameSortable = p.name.toLowerCase();
          // Extract numeric price for sorting (e.g. "$260 / 50-min" → 260); -1 means no price listed (sort last)
          const priceNum = p.pricing ? (p.pricing.match(/\d+/) ? parseInt(p.pricing.match(/\d+/)![0], 10) : -1) : -1;
          return (
            <div
              class="prac-card"
              data-specialties={specialtiesStr}
              data-experience={expNum}
              data-name={nameSortable}
              data-price={priceNum}
              style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.25rem 1.375rem; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: 0.75rem;"
            >
              <!-- Name + registration type -->
              <div>
                <a
                  href={`/directory/${p.slug}/`}
                  style="font-size: 1rem; font-weight: 700; color: var(--color-accent); text-decoration: none; display: block; margin-bottom: 0.2rem;"
                >
                  {p.name}
                </a>
                <span style="font-size: 0.78rem; color: var(--color-text-secondary);">
                  {p.registrationType === "clinical_psychologist" ? "Clinical psychologist" : "Registered psychologist"}
                  {p.suburb ? ` · ${p.suburb}` : ""}
                </span>
              </div>

              <!-- Key data row -->
              <div style="display: flex; flex-wrap: wrap; gap: 0.5rem 1.25rem; font-size: 0.85rem; color: var(--color-text-secondary);">
                {p.yearsExperience && (
                  <span><strong style="color: var(--color-text);">{p.yearsExperience}+</strong> yrs exp</span>
                )}
                {p.pricing && (
                  <span><strong style="color: var(--color-text);">{p.pricing.split('/')[0].trim()}</strong> / session</span>
                )}
                {!p.pricing && (
                  <span>Fees on enquiry</span>
                )}
                {p.bookingUrl && (
                  <span style="color: var(--color-accent); font-weight: 500;">Online booking</span>
                )}
              </div>

              <!-- Specialty chips -->
              <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
                {p.specialties.slice(0, 4).map(s => (
                  <span style="display: inline-block; font-size: 0.73rem; background: var(--color-accent-soft); color: var(--color-accent-hover); border: 1px solid var(--color-accent-light); padding: 0.1rem 0.5rem; border-radius: 100px;">{s}</span>
                ))}
                {p.specialties.length > 4 && (
                  <span style="font-size: 0.73rem; color: var(--color-text-secondary);">+{p.specialties.length - 4} more</span>
                )}
              </div>

              <!-- View profile link -->
              <a
                href={`/directory/${p.slug}/`}
                style="font-size: 0.85rem; font-weight: 600; color: var(--color-accent); text-decoration: none; margin-top: auto;"
                aria-label={`View full profile for ${p.name}`}
              >
                View profile &rarr;
              </a>
            </div>
          );
        })}
      </div>

      <!-- No-results message (hidden by default; shown by JS when needed) -->
      <p id="no-results" style="display: none; text-align: center; color: var(--color-text-secondary); padding: 2.5rem 0; font-size: 1rem;">
        No practitioners match this filter. <button onclick="document.getElementById('clear-filters').click()" style="background: none; border: none; color: var(--color-accent); cursor: pointer; font-size: 1rem; font-weight: 600; padding: 0;">Clear the filter</button> to see all {practitioners.length} psychologists.
      </p>

      <!-- ALL PRACTITIONERS: at-a-glance comparison table (kept for SEO + reference) -->
      <div style="margin-bottom: 3.5rem;">
        <h2 style="margin-bottom: 0.5rem;">At-a-glance comparison table</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 1.5rem; font-size: 0.95rem; max-width: 640px;">
          Compare experience, pricing, and specialties side by side. Click any name for the full profile with bio and booking link.
        </p>

        <div style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
          <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem; min-width: 600px;">
            <thead>
              <tr style="border-bottom: 2px solid var(--color-border); text-align: left;">
                <th style="padding: 0.75rem 1rem; font-weight: 700; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-hover); white-space: nowrap;">Practitioner</th>
                <th style="padding: 0.75rem 1rem; font-weight: 700; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-hover); white-space: nowrap;">Experience</th>
                <th style="padding: 0.75rem 1rem; font-weight: 700; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-hover); white-space: nowrap;">Session fee</th>
                <th style="padding: 0.75rem 1rem; font-weight: 700; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-accent-hover);">Key specialties</th>
              </tr>
            </thead>
            <tbody>
              {practitioners.map((p, i) => (
                <tr style={`border-bottom: 1px solid var(--color-border); background: ${i % 2 === 0 ? 'transparent' : 'var(--color-surface)'};`}>
                  <td style="padding: 0.85rem 1rem; vertical-align: top;">
                    <a href={`/directory/${p.slug}/`} style="font-weight: 600; color: var(--color-accent); text-decoration: none; display: block; margin-bottom: 0.2rem;">{p.name}</a>
                    <span style="font-size: 0.78rem; color: var(--color-text-secondary);">
                      {p.registrationType === "clinical_psychologist" ? "Clinical psychologist" : "Registered psychologist"}
                    </span>
                  </td>
                  <td style="padding: 0.85rem 1rem; vertical-align: top; white-space: nowrap; color: var(--color-text-secondary);">
                    {p.yearsExperience ? `${p.yearsExperience}+ yrs` : '—'}
                  </td>
                  <td style="padding: 0.85rem 1rem; vertical-align: top; white-space: nowrap;">
                    {p.pricing
                      ? <span style="color: var(--color-text); font-weight: 500;">{p.pricing.split('/')[0].trim()}</span>
                      : <span style="color: var(--color-text-secondary); font-size: 0.85rem;">On enquiry</span>
                    }
                  </td>
                  <td style="padding: 0.85rem 1rem; vertical-align: top;">
                    <div style="display: flex; flex-wrap: wrap; gap: 0.3rem;">
                      {p.specialties.slice(0, 3).map(s => (
                        <span style="display: inline-block; font-size: 0.75rem; background: var(--color-accent-soft); color: var(--color-accent-hover); border: 1px solid var(--color-accent-light); padding: 0.1rem 0.5rem; border-radius: 100px;">{s}</span>
                      ))}
                      {p.specialties.length > 3 && (
                        <span style="font-size: 0.75rem; color: var(--color-text-secondary);">+{p.specialties.length - 3}</span>
                      )}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p style="font-size: 0.78rem; color: var(--color-text-secondary); margin-top: 0.75rem;">
          Profiles sourced from practitioners' own public websites. Unverified by the directory — see each profile for source attribution.
          Medicare rebate: up to $98.95/session (registered psychologist) with a valid Mental Health Care Plan from your GP.
        </p>
      </div>

      <!-- Pillar → guides: links DOWN to all cluster guides -->
      <div style="margin-bottom: 3rem; padding: 1.5rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius);">
        <h2 style="margin-bottom: 0.5rem; font-size: 1.15rem;">Guides: understanding telehealth psychology for anxiety</h2>
        <p style="color: var(--color-text-secondary); font-size: 0.93rem; margin-bottom: 1rem;">Before or after browsing profiles, these guides answer the most common questions about cost, evidence, and the process.</p>
        <ul style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.5rem 1.5rem; padding-left: 1.25rem; margin: 0;">
          <li><a href="/guides/cost-telehealth-psychologist-australia/">What does a telehealth psychologist cost? (fees + Medicare rebates)</a></li>
          <li><a href="/guides/mental-health-care-plan-sydney/">How to get a Mental Health Care Plan from your GP</a></li>
          <li><a href="/guides/does-online-therapy-work-for-anxiety/">Does online therapy work for anxiety? (evidence review)</a></li>
          <li><a href="/guides/how-telehealth-psychology-works/">How a telehealth session actually works</a></li>
          <li><a href="/guides/how-to-choose-anxiety-psychologist-telehealth/">How to choose a telehealth psychologist for anxiety</a></li>
          <li><a href="/guides/bulk-billing-psychologist-sydney/">Bulk billing for psychologists in Sydney</a></li>
          <li><a href="/guides/psychologist-waitlist-sydney/">Sydney psychology waitlists — what to do</a></li>
          <li><a href="/guides/clinical-psychologist-vs-registered-psychologist/">Clinical vs registered psychologist: the practical difference</a></li>
          <li><a href="/guides/social-anxiety-telehealth-psychologist-sydney/">Social anxiety: telehealth psychology in Sydney</a></li>
          <li><a href="/guides/panic-disorder-telehealth-psychologist-sydney/">Panic disorder and telehealth psychology</a></li>
          <li><a href="/guides/health-anxiety-telehealth-psychologist-sydney/">Health anxiety (illness anxiety): what helps</a></li>
          <li><a href="/guides/ocd-telehealth-psychologist-sydney/">OCD and ERP via telehealth in Sydney</a></li>
          <li><a href="/guides/generalised-anxiety-disorder-telehealth-psychologist-sydney/">Generalised anxiety disorder (GAD) and telehealth psychology</a></li>
          <li><a href="/guides/medicare-psychology-data-australia/">Medicare psychology data: who accesses rebates and how often</a></li>
          <li><a href="/guides/ptsd-telehealth-psychologist-sydney/">PTSD and trauma: telehealth psychology in Sydney</a></li>
          <li><a href="/guides/anxiety-depression-telehealth-psychologist-sydney/">Anxiety and depression together: telehealth psychology</a></li>
          <li><a href="/guides/evening-weekend-psychologist-sydney/">Evening and weekend telehealth psychologist in Sydney</a></li>
          <li><a href="/guides/agoraphobia-telehealth-psychologist-sydney/">Agoraphobia: telehealth psychology in Sydney</a></li>
        </ul>
      </div>

      <!-- SECONDARY: Browse by suburb (SEO value) -->
      <div style="margin-bottom: 3rem;">
        <h2 style="margin-bottom: 0.5rem;">Browse by suburb</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 1.25rem; font-size: 0.95rem; max-width: 600px;">
          Because all sessions are delivered via telehealth, suburb matters less than specialty — but suburb-level pages may help if you prefer a psychologist based near you.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.65rem;">
          <a href="/find/anxiety-psychologist-bondi-junction-sydney/" style="display: inline-block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.5rem 1rem; font-size: 0.88rem; text-decoration: none; color: var(--color-text);">Bondi Junction</a>
          <a href="/find/anxiety-psychologist-north-sydney-sydney/" style="display: inline-block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.5rem 1rem; font-size: 0.88rem; text-decoration: none; color: var(--color-text);">North Sydney</a>
          <a href="/find/anxiety-psychologist-surry-hills-sydney/" style="display: inline-block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.5rem 1rem; font-size: 0.88rem; text-decoration: none; color: var(--color-text);">Surry Hills</a>
          <a href="/find/anxiety-psychologist-edgecliff-sydney/" style="display: inline-block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.5rem 1rem; font-size: 0.88rem; text-decoration: none; color: var(--color-text);">Edgecliff / Eastern Suburbs</a>
          <a href="/find/anxiety-psychologist-marrickville-sydney/" style="display: inline-block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.5rem 1rem; font-size: 0.88rem; text-decoration: none; color: var(--color-text);">Marrickville / Inner West</a>
          <a href="/find/anxiety-psychologist-strathfield-sydney/" style="display: inline-block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.5rem 1rem; font-size: 0.88rem; text-decoration: none; color: var(--color-text);">Strathfield</a>
          <a href="/find/anxiety-psychologist-chippendale-sydney/" style="display: inline-block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.5rem 1rem; font-size: 0.88rem; text-decoration: none; color: var(--color-text);">Chippendale / CBD</a>
          <a href="/find/anxiety-psychologist-zetland-sydney/" style="display: inline-block; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 0.5rem 1rem; font-size: 0.88rem; text-decoration: none; color: var(--color-text);">Zetland / Green Square</a>
