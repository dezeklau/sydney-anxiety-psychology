---
import Base from '../../../layouts/Base.astro';
import AuthorByline from '../../../components/AuthorByline.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many psychology sessions do I need for anxiety?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There is no single answer — it depends on the type of anxiety, its severity, and how you respond to treatment. Evidence-based treatments for anxiety disorders (particularly cognitive behavioural therapy, or CBT) typically show meaningful improvement within 8 to 20 sessions for most presentations. Many people notice significant changes within the first 6 to 8 sessions; others with more complex or long-standing presentations benefit from longer-term work. Medicare allows up to 10 individual psychology sessions per calendar year under a Mental Health Treatment Plan, which covers a standard course of CBT for many anxiety presentations."
      }
    },
    {
      "@type": "Question",
      "name": "Is 10 sessions enough for anxiety?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For many people with anxiety disorders, 10 sessions of CBT is enough to make substantial progress. Clinical guidelines (including those from the National Institute for Health and Care Excellence) suggest that a standard course of CBT for generalised anxiety disorder, social anxiety, or panic disorder is typically 12 to 20 sessions. However, evidence shows that many people achieve their treatment goals within 10 sessions, particularly for less complex presentations. If more sessions are needed beyond the Medicare-covered 10, your psychologist can discuss options including self-funded sessions, whether private health insurance covers additional sessions, or whether your GP can review the plan."
      }
    },
    {
      "@type": "Question",
      "name": "What happens after I use my 10 Medicare sessions for anxiety?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Once you have used your 10 Medicare-subsidised sessions in a calendar year, further sessions are available but are not subsidised by Medicare unless you start a new calendar year. Options include: continuing with self-funded sessions at the psychologist's standard fee; checking whether your private health insurance covers additional psychology sessions; or speaking with your GP about whether other Medicare pathways (such as a chronic disease plan) may apply to your situation. Your psychologist can also discuss whether a break and review approach is appropriate for your presentation."
      }
    },
    {
      "@type": "Question",
      "name": "Does telehealth psychology work as well as in-person for anxiety?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The evidence for telehealth CBT for anxiety disorders is strong. A 2023 meta-analysis published in JMIR Mental Health (Shaker et al.) found that internet-delivered and video-based CBT produced outcomes equivalent to in-person CBT for anxiety disorders. The same Medicare rebate applies to telehealth sessions as in-person sessions under Better Access. Telehealth also offers practical advantages: shorter wait times, no travel time, and the ability to access specialists regardless of your suburb."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
