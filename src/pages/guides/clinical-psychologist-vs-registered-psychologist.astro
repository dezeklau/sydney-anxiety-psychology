>
  <div class="main-content">
    <div class="container">

      <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1.5rem;">
        <a href="/">Home</a> &rsaquo; <a href="/guides/">Guides</a> &rsaquo; Clinical vs Registered Psychologist
