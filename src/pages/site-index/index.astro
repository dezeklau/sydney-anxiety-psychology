---
import Base from '../../layouts/Base.astro';
import { practitioners } from '../../data/practitioners';

// A complete, human-readable index of every page on the site.
// Purpose: flatten crawl depth (every page reachable in <=2 clicks from any page
// via the sitewide footer link) and give each interior URL an extra internal link.
// Anti-fabrication: every URL below was verified to exist in the build this cycle.

const startHere = [
  { href: '/', label: 'Home' },
  { href: '/directory/', label: 'Browse the directory of telehealth anxiety psychologists' },
  { href: '/connect/', label: 'Find a psychologist (tell us what you need)' },
];

const guides = [
  { href: '/guides/', label: 'Guides index' },
  { href: '/guides/telehealth-anxiety-psychology-sydney/', label: 'PILLAR: Telehealth anxiety psychology Sydney — complete guide' },
  { href: '/guides/cost-telehealth-psychologist-australia/', label: 'What does a telehealth psychologist cost in Australia?' },
  { href: '/guides/mental-health-care-plan-sydney/', label: 'Mental Health Care Plan Sydney: how to get one' },
  { href: '/guides/bulk-billing-psychologist-sydney/', label: 'Bulk billing for psychologists in Sydney' },
  { href: '/guides/clinical-psychologist-vs-registered-psychologist/', label: 'Clinical vs registered psychologist' },
  { href: '/guides/how-to-choose-anxiety-psychologist-telehealth/', label: 'How to choose a telehealth psychologist for anxiety' },
  { href: '/guides/how-telehealth-psychology-works/', label: 'How telehealth psychology works' },
  { href: '/guides/does-online-therapy-work-for-anxiety/', label: 'Does online therapy work for anxiety?' },
  { href: '/guides/psychologist-waitlist-sydney/', label: 'Psychology waitlists in Sydney: what to know' },
  { href: '/guides/medicare-psychology-data-australia/', label: 'Medicare-rebated psychology in Australia: what the data shows' },
];

const tools = [
  { href: '/tools/', label: 'Free tools hub' },
  { href: '/tools/medicare-rebate-calculator/', label: 'Medicare rebate and gap calculator' },
  { href: '/tools/mental-health-care-plan-checker/', label: 'Mental Health Care Plan eligibility checker' },
];

const conditionGuides = [
  { href: '/guides/generalised-anxiety-disorder-telehealth-psychologist-sydney/', label: 'Generalised anxiety disorder (GAD)' },
  { href: '/guides/social-anxiety-telehealth-psychologist-sydney/', label: 'Social anxiety' },
  { href: '/guides/panic-disorder-telehealth-psychologist-sydney/', label: 'Panic disorder and panic attacks' },
  { href: '/guides/health-anxiety-telehealth-psychologist-sydney/', label: 'Health anxiety (illness anxiety)' },
  { href: '/guides/ocd-telehealth-psychologist-sydney/', label: 'OCD (ERP via video)' },
  { href: '/guides/ptsd-telehealth-psychologist-sydney/', label: 'PTSD and trauma: telehealth psychology in Sydney' },
  { href: '/guides/anxiety-depression-telehealth-psychologist-sydney/', label: 'Anxiety and depression together' },
  { href: '/guides/evening-weekend-psychologist-sydney/', label: 'Evening and weekend telehealth psychologist in Sydney' },
  { href: '/guides/agoraphobia-telehealth-psychologist-sydney/', label: 'Agoraphobia: telehealth psychology in Sydney' },
  { href: '/guides/work-related-anxiety-psychologist-sydney/', label: 'Work-related anxiety: finding a telehealth psychologist in Sydney' },
  { href: '/guides/first-psychology-session-what-to-expect/', label: 'What to expect from your first psychology session' },
];

const suburbs = [
  { href: '/find/anxiety-psychologist-bondi-junction-sydney/', label: 'Bondi Junction' },
  { href: '/find/anxiety-psychologist-north-sydney-sydney/', label: 'North Sydney' },
  { href: '/find/anxiety-psychologist-surry-hills-sydney/', label: 'Surry Hills' },
  { href: '/find/anxiety-psychologist-edgecliff-sydney/', label: 'Edgecliff' },
  { href: '/find/anxiety-psychologist-marrickville-sydney/', label: 'Marrickville' },
  { href: '/find/anxiety-psychologist-strathfield-sydney/', label: 'Strathfield' },
  { href: '/find/anxiety-psychologist-beverly-hills-sydney/', label: 'Beverly Hills' },
  { href: '/find/anxiety-psychologist-chippendale-sydney/', label: 'Chippendale' },
  { href: '/find/anxiety-psychologist-zetland-sydney/', label: 'Zetland' },
];

const faqPages = [
  { href: '/faq/', label: 'Common questions index' },
  { href: '/faq/how-many-sessions-do-i-need-for-anxiety/', label: 'How many sessions do I need for anxiety?' },
  { href: '/faq/does-medicare-cover-telehealth-psychology/', label: 'Does Medicare cover telehealth psychology sessions?' },
  { href: '/faq/psychologist-wait-times-sydney/', label: 'How long is the wait to see a psychologist in Sydney?' },
  { href: '/faq/psychologist-vs-psychiatrist-sydney/', label: 'Psychologist vs psychiatrist for anxiety in Sydney' },
];

const aboutInfo = [
  { href: '/about/', label: 'About this directory' },
  { href: '/for-psychologists/', label: 'For psychologists (list your practice)' },
  { href: '/listing-removal/', label: 'Listing removal request' },
  { href: '/privacy/', label: 'Privacy policy' },
];

const practitionerCount = practitioners.length;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://sydneyanxietypsychology.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Site index", "item": "https://sydneyanxietypsychology.com.au/site-index/" },
  ]
};
---
<Base
  title="Site index | Sydney Anxiety Psychology"
  description="A complete index of every page on Sydney Anxiety Psychology: the directory, guides, condition pages, and suburb pages for telehealth anxiety psychologists in Sydney."
  schema={[breadcrumbSchema]}
>
  <div class="main-content">
    <div class="container">

      <p style="font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1.5rem;">
        <a href="/">Home</a> &rsaquo; Site index
      </p>

      <h1>Site index</h1>
      <p style="font-size: 1.05rem; color: var(--color-text-secondary); margin-bottom: 2.5rem;">Every page on this site, in one place. Use it to find a guide, a suburb, or the directory quickly.</p>

      <section style="margin-bottom: 2.5rem;">
        <h2 style="font-size: 1.2rem;">Start here</h2>
        <ul style="line-height: 1.9;">
          {startHere.map((p) => <li><a href={p.href}>{p.label}</a></li>)}
        </ul>
      </section>

      <section style="margin-bottom: 2.5rem;">
        <h2 style="font-size: 1.2rem;">Guides</h2>
        <ul style="line-height: 1.9;">
          {guides.map((p) => <li><a href={p.href}>{p.label}</a></li>)}
        </ul>
      </section>

      <section style="margin-bottom: 2.5rem;">
        <h2 style="font-size: 1.2rem;">Anxiety conditions</h2>
        <ul style="line-height: 1.9;">
          {conditionGuides.map((p) => <li><a href={p.href}>{p.label}</a></li>)}
        </ul>
      </section>

      <section style="margin-bottom: 2.5rem;">
        <h2 style="font-size: 1.2rem;">Free tools</h2>
        <ul style="line-height: 1.9;">
          {tools.map((p) => <li><a href={p.href}>{p.label}</a></li>)}
        </ul>
      </section>

      <section style="margin-bottom: 2.5rem;">
        <h2 style="font-size: 1.2rem;">Find a psychologist by area</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 0.75rem;">These pages list psychologists who offer telehealth across Sydney but are based near each area. Telehealth means you can work with any of them wherever you are.</p>
        <ul style="line-height: 1.9;">
          {suburbs.map((p) => <li><a href={p.href}>Anxiety psychologists near {p.label}</a></li>)}
        </ul>
      </section>

      <section style="margin-bottom: 2.5rem;">
        <h2 style="font-size: 1.2rem;">The directory</h2>
        <ul style="line-height: 1.9;">
          <li><a href="/directory/">Browse all {practitionerCount} listed psychologists</a></li>
        </ul>
      </section>

      <section style="margin-bottom: 2.5rem;">
        <h2 style="font-size: 1.2rem;">Common questions</h2>
        <ul style="line-height: 1.9;">
          {faqPages.map((p) => <li><a href={p.href}>{p.label}</a></li>)}
        </ul>
      </section>

      <section style="margin-bottom: 2.5rem;">
        <h2 style="font-size: 1.2rem;">About &amp; info</h2>
        <ul style="line-height: 1.9;">
          {aboutInfo.map((p) => <li><a href={p.href}>{p.label}</a></li>)}
        </ul>
      </section>

    </div>
  </div>
</Base>
