---
import '../styles/global.css';
// Base layout: all pages inherit from this
interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object;
  ogImage?: string;
}

const { title, description, canonical, schema, ogImage } = Astro.props;
const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = ogImage || 'https://sydneyanxietypsychology.com.au/og-image.png';
const plausibleDomain = 'sydneyanxietypsychology.com.au'; // domain registered; activate when Plausible account is live
---
<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_AU" />
  <meta property="og:site_name" content="Sydney Anxiety Psychology" />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Sydney Anxiety Psychology — Telehealth Psychologist Directory" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  <!-- Privacy-friendly analytics by Plausible -->
  <script is:inline async src="https://plausible.io/js/pa-y-f7oqo_wQxjvFaqQXMIZ.js"></script>
  <script is:inline>
    window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
    plausible.init()
  </script>

  <!-- Organization schema (sitewide) -->
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Sydney Anxiety Psychology",
    "url": "https://sydneyanxietypsychology.com.au",
    "logo": {
      "@type": "ImageObject",
      "url": "https://sydneyanxietypsychology.com.au/og-image.png",
      "width": 1200,
      "height": 630
    },
    "description": "An independent directory helping people in Sydney find AHPRA-registered telehealth psychologists who specialise in anxiety. Not a clinical service.",
    "areaServed": {
      "@type": "City",
      "name": "Sydney",
      "sameAs": "https://www.wikidata.org/wiki/Q3130"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "url": "https://sydneyanxietypsychology.com.au/connect/"
    }
  })}</script>

  <!-- Schema.org JSON-LD (page-level) -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!-- Google Fonts: Lora (headings) + Inter (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@500;600;700&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <div class="site-header__inner">
      <a href="/" class="site-header__logo">
        <span class="site-header__mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
        </span>
        <span class="site-header__name">Sydney Anxiety Psychology<span class="site-header__sub">Telehealth Psychologist Directory</span></span>
      </a>
      <nav class="site-header__nav">
        <a href="/directory/">Browse directory</a>
        <a href="/guides/cost-telehealth-psychologist-australia/">Costs &amp; rebates</a>
        <a href="/guides/">Guides</a>
        <a href="/for-psychologists/">For psychologists</a>
      </nav>
      <a href="/connect/" class="site-header__cta plausible-event-name=Header+CTA+Click">
        Find a Psychologist
      </a>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <div>
        <strong style="color: rgba(255,255,255,0.9); display: block; margin-bottom: 0.5rem;">Sydney Anxiety Psychology</strong>
        <p style="margin-bottom: 0;">A directory helping people in Sydney find telehealth psychologists for anxiety. Not a clinical service.</p>
      </div>
      <div>
        <ul style="list-style: none; padding: 0;">
          <li style="margin-bottom: 0.4rem;"><a href="/guides/cost-telehealth-psychologist-australia/">What does it cost?</a></li>
          <li style="margin-bottom: 0.4rem;"><a href="/guides/bulk-billing-psychologist-sydney/">Bulk billing for psychologists</a></li>
          <li style="margin-bottom: 0.4rem;"><a href="/guides/does-online-therapy-work-for-anxiety/">Does online therapy work?</a></li>
          <li style="margin-bottom: 0.4rem;"><a href="/guides/how-telehealth-psychology-works/">How does it work?</a></li>
          <li style="margin-bottom: 0.4rem;"><a href="/guides/psychologist-waitlist-sydney/">Waitlists &amp; availability</a></li>
          <li style="margin-bottom: 0.4rem;"><a href="/guides/clinical-psychologist-vs-registered-psychologist/">Clinical vs registered psychologist</a></li>
          <li style="margin-bottom: 0.4rem;"><a href="/for-psychologists/">For psychologists</a></li>
          <li style="margin-bottom: 0.4rem;"><a href="/connect/">Find a Psychologist</a></li>
          <li style="margin-bottom: 0.4rem;"><a href="/about/">About This Directory</a></li>
          <li style="margin-bottom: 0.4rem;"><a href="/privacy/">Privacy Policy</a></li>
        </ul>
      </div>
      <p class="site-footer__disclaimer">
        This website is a directory resource. It does not provide clinical, psychological, or medical advice. Information is provided in good faith for general educational purposes and should not replace professional advice. For urgent mental health support, contact Lifeline on <strong style="color: rgba(255,255,255,0.7);">13 11 14</strong>, Beyond Blue on <strong style="color: rgba(255,255,255,0.7);">1300 22 4636</strong>, or 13YARN on <strong style="color: rgba(255,255,255,0.7);">13 92 76</strong>. This directory is not a crisis service. Medicare rebate information is current as at 1 July 2025; verify current rates at health.gov.au. Last reviewed June 2026.
      </p>
    </div>
  </footer>
</body>
</html>
