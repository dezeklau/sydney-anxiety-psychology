---
/**
 * AuthorByline component — used on guide pages for E-E-A-T signalling.
 *
 * OPERATOR NAME: Currently a placeholder. To activate:
 * 1. Derek confirms the operator name and role description
 * 2. Replace the placeholder below with the confirmed name
 * 3. Optionally add a small headshot to /public/operator-photo.jpg and update photoSrc
 *
 * AHPRA NOTE: The operator is NOT described as a psychologist or health practitioner.
 * The role is "directory curator & health researcher" — accurate and non-clinical.
 */

interface Props {
  datePublished?: string;
  dateModified?: string;
}

const { datePublished, dateModified } = Astro.props;

const OPERATOR_NAME = "Editorial Team";
const OPERATOR_ROLE = "Sydney Anxiety Psychology Directory";
---
<div style="display: flex; align-items: flex-start; gap: 0.85rem; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1rem 1.25rem; margin-bottom: 2rem; font-size: 0.875rem;">
  <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--color-accent-soft); border: 2px solid var(--color-accent-light); display: flex; align-items: center; justify-content: center; flex-shrink: 0;" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
  </div>
  <div>
    <div style="font-weight: 600; color: var(--color-text); margin-bottom: 0.15rem;">{OPERATOR_NAME}</div>
    <div style="color: var(--color-text-secondary);">{OPERATOR_ROLE}</div>
    {(datePublished || dateModified) && (
      <div style="color: var(--color-text-secondary); margin-top: 0.25rem;">
        {dateModified
          ? `Last updated: ${dateModified}`
          : datePublished
            ? `Published: ${datePublished}`
            : null}
      </div>
    )}
    <div style="margin-top: 0.35rem; color: var(--color-text-secondary); font-size: 0.8rem;">
      This directory is not a clinical service. <a href="/about/">About this directory &rarr;</a>
    </div>
  </div>
</div>
