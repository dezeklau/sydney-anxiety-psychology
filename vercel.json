{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "redirects": [
    {
      "source": "http://sydneyanxietypsychology.com.au/(.*)",
      "destination": "https://sydneyanxietypsychology.com.au/$1",
      "permanent": true
    },
    {
      "source": "http://www.sydneyanxietypsychology.com.au/(.*)",
      "destination": "https://sydneyanxietypsychology.com.au/$1",
      "permanent": true
    },
    {
      "source": "https://www.sydneyanxietypsychology.com.au/(.*)",
      "destination": "https://sydneyanxietypsychology.com.au/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        }
      ]
    }
  ]
}
